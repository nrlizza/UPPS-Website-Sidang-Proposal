<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - UPPS</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          backgroundImage: {
            'gradient-blue': 'linear-gradient(to top, rgb(23 37 84), rgba(30 58 138 / 0.4), transparent)'
          }
        }
      }
    }
  </script>
  <style>
    @keyframes spin { to { transform: rotate(360deg); } }
    .animate-spin { animation: spin 1s linear infinite; }
  </style>
</head>
<body>

  <div class="min-h-screen flex items-center justify-center p-4" style="background-image: url('/images/paramadina.svg'); background-size: cover; background-position: center;">
    <div class="bg-white rounded-2xl shadow-xl overflow-hidden w-full max-w-4xl flex" style="min-height: 520px;">

      <!-- ─── LEFT PANEL ─── -->
      <div class="flex-1 flex flex-col justify-between p-10 min-w-0">

        <!-- Logo -->
        <div class="mb-4">
          <img src="/images/paramadinalogo.svg" alt="PPSU" class="h-12 object-contain">
        </div>

        <!-- Heading -->
        <div class="flex-1 flex flex-col justify-center">
          <h1 class="text-3xl font-bold text-gray-900 mb-2">
            Selamat Datang di <span class="text-blue-600">UPPS!</span>
          </h1>
          <p class="text-gray-500 text-sm mb-8 leading-relaxed">
            Sistem digital untuk pendaftaran dan persetujuan Sidang Seminar
            Proposal / Sidang Kolokium secara terintegrasi
          </p>

          <!-- Server-side alerts -->
          <% if (locals.success_msg && success_msg.length > 0) { %>
            <p class="text-green-600 text-xs bg-green-50 border border-green-200 rounded-lg px-3 py-2 mb-4">
              <%= success_msg %>
            </p>
          <% } %>
          <% if (locals.error_msg && error_msg.length > 0) { %>
            <p class="text-red-500 text-xs bg-red-50 border border-red-200 rounded-lg px-3 py-2 mb-4">
              <%= error_msg %>
            </p>
          <% } %>
          <% if (locals.error && error.length > 0) { %>
            <p class="text-red-500 text-xs bg-red-50 border border-red-200 rounded-lg px-3 py-2 mb-4">
              <%= error %>
            </p>
          <% } %>

          <!-- Form -->
          <form action="/login" method="POST" id="loginForm" class="space-y-4">
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="Masukkan email anda"
                value="<%= typeof email !== 'undefined' ? email : '' %>"
                required
                autocomplete="email"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent placeholder-gray-400 transition"
              >
            </div>

            <div>
              <label for="password" class="block text-sm font-medium text-gray-700 mb-1">Password</label>
              <div class="relative">
                <input
                  type="password"
                  id="password"
                  name="password"
                  placeholder="Masukkan kata sandi anda"
                  required
                  autocomplete="current-password"
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent placeholder-gray-400 transition pr-11"
                >
                <button
                  type="button"
                  id="togglePassword"
                  aria-label="Tampilkan/sembunyikan kata sandi"
                  class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 transition"
                >
                  <!-- eye icon -->
                  <svg id="eyeIcon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z"></path>
                    <circle cx="12" cy="12" r="3"></circle>
                  </svg>
                  <!-- eye-off icon (hidden by default) -->
                  <svg id="eyeOffIcon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
                    <path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"></path>
                    <path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"></path>
                    <path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"></path>
                    <line x1="2" y1="2" x2="22" y2="22"></line>
                  </svg>
                </button>
              </div>
            </div>

            <!-- Remember me + Forgot password -->
            <div class="flex items-center justify-between text-xs">
              <label class="flex items-center gap-2 text-gray-500 cursor-pointer select-none">
                <input type="checkbox" name="remember" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500">
                Ingat saya
              </label>
              <a href="/forgot-password" class="text-blue-600 hover:text-blue-700 font-medium">Lupa kata sandi?</a>
            </div>

            <!-- Client-side / inline error -->
            <p id="clientError" class="hidden text-red-500 text-xs bg-red-50 border border-red-200 rounded-lg px-3 py-2"></p>

            <button
              type="submit"
              id="loginBtn"
              class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-lg transition flex items-center justify-center gap-2 disabled:opacity-70 disabled:cursor-not-allowed"
            >
              <svg id="btnSpinner" class="hidden animate-spin" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="2" x2="12" y2="6"></line>
                <line x1="12" y1="18" x2="12" y2="22"></line>
                <line x1="4.93" y1="4.93" x2="7.76" y2="7.76"></line>
                <line x1="16.24" y1="16.24" x2="19.07" y2="19.07"></line>
                <line x1="2" y1="12" x2="6" y2="12"></line>
                <line x1="18" y1="12" x2="22" y2="12"></line>
                <line x1="4.93" y1="19.07" x2="7.76" y2="16.24"></line>
                <line x1="16.24" y1="7.76" x2="19.07" y2="4.93"></line>
              </svg>
              <span id="btnText">Login</span>
            </button>
          </form>

          <!-- Divider -->
          <div class="flex items-center gap-3 my-5">
            <div class="flex-1 h-px bg-gray-200"></div>
            <span class="text-xs text-gray-400">atau</span>
            <div class="flex-1 h-px bg-gray-200"></div>
          </div>

           <!-- Google Sign-In Button -->
          <a href="<%= backendBaseUrl %>/api/auth/google"
            class="w-full flex items-center justify-center gap-3 border border-gray-300 hover:bg-gray-50 text-gray-700 font-medium py-3 rounded-lg transition text-sm"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path fill="#4285F4" d="M23.49 12.27c0-.79-.07-1.54-.2-2.27H12v4.51h6.47c-.28 1.48-1.13 2.73-2.4 3.58v2.98h3.89c2.28-2.1 3.53-5.19 3.53-8.8z"/>
              <path fill="#34A853" d="M12 24c3.24 0 5.95-1.08 7.93-2.92l-3.89-2.98c-1.08.72-2.46 1.16-4.04 1.16-3.11 0-5.74-2.1-6.68-4.92H1.32v3.09C3.29 21.3 7.31 24 12 24z"/>
              <path fill="#FBBC05" d="M5.32 14.34c-.24-.72-.38-1.49-.38-2.34s.14-1.62.38-2.34V6.57H1.32C.48 8.24 0 10.06 0 12s.48 3.76 1.32 5.43l4-3.09z"/>
              <path fill="#EA4335" d="M12 4.75c1.76 0 3.34.61 4.58 1.8l3.44-3.44C17.94 1.19 15.24 0 12 0 7.31 0 3.29 2.7 1.32 6.57l4 3.09c.94-2.82 3.57-4.91 6.68-4.91z"/>
            </svg>
            Masuk dengan Google
          </a>
          
        </div>

        <!-- Footer -->
        <div class="mt-8 flex items-center justify-between text-xs text-gray-400">
          <span>Program Pascasarjana | Universitas Paramadina</span>
          <span>© 2026</span>
        </div>

      </div>

      <!-- ─── RIGHT PANEL ─── -->
      <div class="hidden md:block w-80 lg:w-96 relative shrink-0">
        <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/rightlogin.svg');"></div>
        <div class="absolute inset-0 bg-gradient-blue"></div>
        <div class="absolute bottom-0 left-0 right-0 p-6">
          <div class="border-l-4 border-blue-400 pl-4">
            <p class="text-white text-xs leading-relaxed italic opacity-90">
              "Memudahkan pendaftaran dan persetujuan Sidang Seminar Proposal
              serta Sidang Kolokium secara cepat, transparan, dan terdokumentasi."
            </p>
          </div>
        </div>
      </div>

    </div>
  </div>

  <script>
    // Toggle password visibility
    const passwordInput = document.getElementById('password');
    const toggleBtn = document.getElementById('togglePassword');
    const eyeIcon = document.getElementById('eyeIcon');
    const eyeOffIcon = document.getElementById('eyeOffIcon');

    toggleBtn.addEventListener('click', () => {
      const isPassword = passwordInput.type === 'password';
      passwordInput.type = isPassword ? 'text' : 'password';
      eyeIcon.classList.toggle('hidden', isPassword);
      eyeOffIcon.classList.toggle('hidden', !isPassword);
    });

    // Loading state + basic required-field validation on submit
    const form = document.getElementById('loginForm');
    const emailInput = document.getElementById('email');
    const clientError = document.getElementById('clientError');
    const loginBtn = document.getElementById('loginBtn');
    const btnText = document.getElementById('btnText');
    const btnSpinner = document.getElementById('btnSpinner');

    form.addEventListener('submit', (e) => {
      clientError.classList.add('hidden');

      if (!emailInput.value || !passwordInput.value) {
        e.preventDefault();
        clientError.textContent = 'Email dan password wajib diisi.';
        clientError.classList.remove('hidden');
        return;
      }

      loginBtn.disabled = true;
      btnText.textContent = 'Memproses...';
      btnSpinner.classList.remove('hidden');
    });
  </script>

</body>
</html>
