<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard Admin - PPSU</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>

  <%- include('../partials/sidebar_admin', { user: locals.user, currentPath: locals.currentPath }) %>

  <div class="min-h-screen flex flex-col">

   <!-- ─── HEADER ─── -->
<header class="bg-white border-b border-gray-200 px-6 py-4 flex items-center justify-between" style="padding-left: 64px;">
  <div class="flex items-center gap-3">
    <img src="/images/paramadinalogo.svg" alt="PPSU" class="h-9 object-contain">
  </div>
      <div class="flex items-center gap-4">
        <div class="text-right">
          <p class="text-sm font-medium text-gray-800"><%= user.name %></p>
          <p class="text-xs text-gray-500"><%= user.jabatan %></p>
        </div>
        <form action="/logout" method="GET">
          <button
            type="submit"
            class="flex items-center gap-2 text-sm text-gray-500 hover:text-red-600 border border-gray-200 rounded-lg px-3 py-2 hover:border-red-200 transition"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
              <polyline points="16 17 21 12 16 7"></polyline>
              <line x1="21" y1="12" x2="9" y2="12"></line>
            </svg>
            Logout
          </button>
        </form>
      </div>
    </header>

    <!-- ─── HERO SECTION ─── -->
    <section class="relative w-full" style="height: calc(100vh - 64px); background-image: url('/images/paramadina.svg'); background-size: cover; background-position: center; background-repeat: no-repeat;">

      <!-- Dark overlay -->
      <div class="absolute inset-0" style="background-color: rgba(0,0,0,0.45);"></div>

      <!-- Hero content — centered -->
      <div class="absolute inset-0 flex flex-col items-center justify-center text-center px-6" style="z-index: 10;">
        <h1 class="font-bold text-white mb-3" style="font-size: clamp(2rem, 4vw, 3rem); text-shadow: 0 2px 8px rgba(0,0,0,0.5);">
          Selamat Datang, <%= user.name %>!
        </h1>
        <p class="text-white mb-6" style="font-size: 1.5rem; opacity: 0.92;">
          Kelola pendaftaran Sidang Seminar Proposal / Sidang Kolokium di sini.
        </p>

        <!-- Buttons -->
        <div class="flex flex-row items-center gap-5 flex-wrap justify-center">
          
          <!-- Tombol Kelola Pengajuan -->
          <a
            href="/dashboard/admin/kelola-pengajuan"
            class="inline-flex items-center justify-center rounded-full text-white font-semibold transition"
            style="padding: 12px 36px; background-color: #2563EB; font-size: 0.95rem; border: 2px solid #2563EB; min-width: 200px;"
            onmouseover="this.style.backgroundColor='#1d4ed8'"
            onmouseout="this.style.backgroundColor='#2563EB'"
          >
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
            </svg>
            Kelola Pengajuan
          </a>
          
          <!-- Tombol Data Management -->
          <a
            href="/dashboard/admin/data-management"
            class="inline-flex items-center justify-center rounded-full font-semibold transition"
            style="padding: 12px 36px; background-color: transparent; color: #fff; font-size: 0.95rem; border: 2px solid #fff; min-width: 200px;"
            onmouseover="this.style.backgroundColor='#fff'; this.style.color='#1d4ed8'"
            onmouseout="this.style.backgroundColor='transparent'; this.style.color='#fff'"
          >
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2"></path>
            </svg>
            Data Management
          </a>
        </div>
      </div>
    </section>
    <!-- ─── FOOTER ─── -->
    <footer style="background-color: #1a56b0;">

      <!-- Main footer -->
      <div class="flex items-stretch flex-col md:flex-row">

        <!-- Kiri — konten footer -->
        <div class="flex-1 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-10" style="padding: 44px 40px 36px;">

          <!-- Kantor Pusat -->
          <div>
            <p class="font-bold text-white text-sm mb-2">Kantor Pusat</p>
            <p class="text-xs leading-relaxed" style="color: #bfdbfe;">
              Universitas Paramadina<br>
              Jl. Gatot Subroto Kav. 97,<br>
              Mampang Prapatan<br>
              Jakarta Selatan 12790
            </p>
          </div>

          <!-- Kontak -->
          <div>
            <p class="font-bold text-white text-sm mb-3">Kontak</p>
            <div class="flex items-center gap-2 text-xs mb-2" style="color: #bfdbfe;">
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"></path>
              </svg>
              <span>+62 21 7918 9000</span>
            </div>
            <div class="flex items-center gap-2 text-xs" style="color: #bfdbfe;">
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 9 6 2 18 2 18 9"></polyline>
                <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path>
                <rect x="6" y="14" width="12" height="8"></rect>
              </svg>
              <span>+62 21 7918 9001</span>
            </div>
          </div>

          <!-- Informasi -->
          <div>
            <p class="font-bold text-white text-sm mb-3">Informasi</p>
            <a href="#" class="block text-xs mb-2 hover:text-white transition" style="color: #bfdbfe;">Tentang PPSU</a>
            <a href="#" class="block text-xs mb-2 hover:text-white transition" style="color: #bfdbfe;">Panduan Pengguna</a>
            <a href="#" class="block text-xs mb-2 hover:text-white transition" style="color: #bfdbfe;">FAQ</a>
          </div>

          <!-- Layanan -->
          <div>
            <p class="font-bold text-white text-sm mb-3">Layanan</p>
            <a href="#" class="block text-xs mb-2 hover:text-white transition" style="color: #bfdbfe;">Sidang Seminar Proposal</a>
            <a href="#" class="block text-xs mb-2 hover:text-white transition" style="color: #bfdbfe;">Sidang Kolokium</a>
            <a href="#" class="block text-xs mb-2 hover:text-white transition" style="color: #bfdbfe;">Status Pengajuan</a>
          </div>

          <!-- Dukungan -->
          <div>
            <p class="font-bold text-white text-sm mb-3">Dukungan</p>
            <a href="mailto:ppsu@paramadina.ac.id" class="block text-xs mb-2 hover:text-white transition" style="color: #bfdbfe; word-break: break-all;">ppsu@paramadina.ac.id</a>
            <a href="#" class="block text-xs mb-2 hover:text-white transition" style="color: #bfdbfe;">Hubungi Kami</a>
            <a href="#" class="block text-xs mb-2 hover:text-white transition" style="color: #bfdbfe;">Kebijakan Privasi</a>
          </div>
        </div>

        <!-- Kanan — kotak logo -->
        <div class="flex items-center justify-center" style="background-color: #005FA2; min-width: 220px; padding: 40px 32px;">
          <img
            src="/images/paramadinalogo-white.svg"
            alt="Universitas Paramadina"
            style="width: 160px; object-fit: contain;"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
          >
          <div style="display: none; flex-direction: column; align-items: center; gap: 8px; color: #fff;">
            <span style="font-weight: 900; font-size: 1.5rem; letter-spacing: 2px;">UP</span>
            <span style="font-weight: 700; font-size: 0.85rem; letter-spacing: 1px; text-align: center;">UNIVERSITAS PARAMADINA</span>
          </div>
        </div>

      </div>

      <!-- Divider -->
      <div style="border-top: 1px solid rgba(255,255,255,0.15);"></div>

      <!-- Bottom bar -->
      <div class="flex flex-col sm:flex-row items-center justify-between gap-2" style="padding: 14px 40px;">
        <p class="text-xs" style="color: #bfdbfe;">
          © <%= new Date().getFullYear() %> Universitas Paramadina. Hak Cipta Dilindungi.
        </p>
        <p class="text-xs" style="color: #bfdbfe;">
          PPSU — Pendaftaran dan Persetujuan Sidang Seminar Proposal/Kolokium
        </p>
      </div>
    </footer>
  </div>

</body>
</html>