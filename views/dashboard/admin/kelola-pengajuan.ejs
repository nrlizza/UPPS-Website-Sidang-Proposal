<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Kelola Pengajuan - PPSU</title>
  <script src="https://cdn.tailwindcss.com">    // Set minimal tanggal jadwal sidang ke besok
    const besok = new Date();
    besok.setDate(besok.getDate() + 1);
    const minDateStr = besok.toISOString().split('T')[0];
    document.querySelectorAll('input[type="date"][name="tanggal"]').forEach(input => {
      input.setAttribute('min', minDateStr);
    });
      // Set minimal tanggal jadwal sidang ke besok
    const besok = new Date();
    besok.setDate(besok.getDate() + 1);
    const minDateStr = besok.toISOString().split('T')[0];
    document.querySelectorAll('input[type="date"][name="tanggal"]').forEach(input => {
      input.setAttribute('min', minDateStr);
    });
  </script>
  <style>
    .status-badge {
      display: inline-flex; align-items: center; gap: 0.3rem;
      padding: 0.3rem 0.75rem; border-radius: 9999px;
      font-size: 0.72rem; font-weight: 600; letter-spacing: 0.01em;
    }
    .status-menunggu   { background: #fef3c7; color: #92400e; }
    .status-disetujui  { background: #d1fae5; color: #065f46; }
    .status-ditolak    { background: #fee2e2; color: #991b1b; }
    .status-selesai    { background: #dbeafe; color: #1e40af; }
    .status-terjadwal  { background: #e0e7ff; color: #3730a3; }

    .card-hover { transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease; }
    .card-hover:hover { transform: translateY(-2px); box-shadow: 0 10px 32px rgba(15, 23, 42, 0.07); border-color: #dbe4f0; }
    .meta-chip svg { color: #1e40af; }

    .modal-overlay {
      position: fixed; inset: 0; background: rgba(15, 23, 42, 0.45);
      display: none; align-items: center; justify-content: center;
      padding: 1rem; z-index: 50;
    }
    .modal-overlay.active { display: flex; }
    @keyframes modalIn { from { opacity: 0; transform: translateY(8px) scale(.98); } to { opacity: 1; transform: translateY(0) scale(1); } }
    .modal-box { animation: modalIn .18s ease both; }
  </style>
</head>
<body class="bg-gray-100">

  <%- include('../../partials/sidebar_admin', { user: locals.user, currentPath: locals.currentPath }) %>

  <div class="min-h-screen">
    <!-- TOP BAR -->
    <div class="bg-white border-b border-gray-200 px-6 py-4 flex items-center justify-between" style="padding-left: 64px;">
      <div class="flex items-center gap-3 pl-8">
        <img src="/images/paramadinalogo.svg" alt="PPSU" class="h-7 object-contain">
        <div class="w-px h-10 bg-gray-200"></div>
        <div class="flex flex-col leading-tight">
          <span class="text-sm font-bold text-gray-800">Kelola Pengajuan</span>
          <span class="text-[10px] font-semibold text-blue-600 uppercase tracking-wider">
            Panel Admin PPSU
          </span>
        </div>
      </div>

      <div class="flex items-center pr-2">
        <a href="/dashboard/admin"
           class="flex items-center gap-2.5 bg-blue-50 hover:bg-blue-100 border border-blue-100 rounded-full pl-2 pr-4 py-1.5 transition-colors shadow-sm">
          <span class="w-6 h-6 rounded-full bg-blue-600 flex items-center justify-center shrink-0">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="7" height="9" x="3" y="3" rx="1"></rect>
              <rect width="7" height="5" x="14" y="3" rx="1"></rect>
              <rect width="7" height="9" x="14" y="12" rx="1"></rect>
              <rect width="7" height="5" x="3" y="16" rx="1"></rect>
            </svg>
          </span>
          <span class="text-xs font-semibold text-blue-700 whitespace-nowrap">Dashboard</span>
        </a>
      </div>
    </div>

    <div class="px-6 py-8" style="padding-left: 64px;">
      <div class="max-w-[1600px] mx-auto">

        <!-- Alert -->
        <% if (locals.success_msg && success_msg.length > 0) { %>
          <div class="bg-green-50 border border-green-200 rounded-lg px-4 py-3 mb-4 text-green-700 text-sm flex items-center gap-2">
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <%= success_msg %>
          </div>
        <% } %>

        <!-- Ringkasan Statistik -->
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3 mb-6">
          <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-4 flex items-center gap-3">
            <span class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0" style="background:#e8effc; color:#1e40af;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
            </span>
            <div><p id="statTotal" class="text-lg font-bold text-gray-800">4</p><p class="text-[11px] font-medium text-gray-400">Total Pengajuan</p></div>
          </div>
          <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-4 flex items-center gap-3">
            <span class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0" style="background:#fef3c7; color:#92400e;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><polyline points="12 7 12 12 15 15"></polyline></svg>
            </span>
            <div><p id="statMenunggu" class="text-lg font-bold text-gray-800">1</p><p class="text-[11px] font-medium text-gray-400">Menunggu</p></div>
          </div>
          <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-4 flex items-center gap-3">
            <span class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0" style="background:#e0e7ff; color:#3730a3;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
            </span>
            <div><p id="statTerjadwal" class="text-lg font-bold text-gray-800">1</p><p class="text-[11px] font-medium text-gray-400">Terjadwal</p></div>
          </div>
          <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-4 flex items-center gap-3">
            <span class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0" style="background:#dbeafe; color:#1e40af;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            </span>
            <div><p id="statSelesai" class="text-lg font-bold text-gray-800">1</p><p class="text-[11px] font-medium text-gray-400">Selesai</p></div>
          </div>
          <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-4 flex items-center gap-3">
            <span class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0" style="background:#fee2e2; color:#991b1b;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>
            </span>
            <div><p id="statDitolak" class="text-lg font-bold text-gray-800">1</p><p class="text-[11px] font-medium text-gray-400">Ditolak</p></div>
          </div>
        </div>

        <!-- Filter / Pencarian -->
        <div class="bg-white rounded-2xl border border-gray-200 p-4 mb-6 shadow-sm">
          <div class="flex flex-col sm:flex-row gap-3 items-center justify-between">
            <div class="flex items-center gap-3 w-full sm:w-auto">
              <div class="relative flex-1 sm:flex-none">
                <input type="text" id="searchInput" placeholder="Cari nama, judul, atau NIM..."
                       class="w-full sm:w-72 pl-10 pr-4 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                <svg class="absolute left-3 top-2.5 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                </svg>
              </div>
              <select id="filterStatus" class="px-3 py-2 border border-gray-300 rounded-lg text-sm text-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500">
                <option value="">Semua Status</option>
                <option value="menunggu">Menunggu</option>
                <option value="terjadwal">Terjadwal</option>
                <option value="selesai">Selesai</option>
                <option value="ditolak">Ditolak</option>
              </select>
               <select id="filterProdi" class="w-full sm:w-auto px-3 py-2 border border-gray-300 rounded-lg text-sm text-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500">
                <option value="">Semua Prodi</option>
                <option value="Teknik Informatika">Teknik Informatika</option>
                <option value="Desain Komunikasi Visual">Desain Komunikasi Visual</option>
                <option value="Desain Produk">Desain Produk</option>
              </select>
            </div>
          </div>
        </div>

        <!-- Daftar Pengajuan -->
        <div class="space-y-4" id="cardList">

          <% if (riwayatList && riwayatList.length > 0) { %>
            <% riwayatList.forEach(p => { 
                // Admin hanya melihat proposal yang sudah disetujui dospem (status == 'ditandatangani')
                if (p.status !== 'ditandatangani') return;

                let cardStatus = p.statusAdmin;
                if (p.statusKaprodi === 'ditolak') cardStatus = 'ditolak';

                // Hanya tampilkan pengajuan yang Menunggu atau Ditolak di Kelola Pengajuan
                if (cardStatus === 'terjadwal' || cardStatus === 'selesai') return;

                let badgeText = '';
                let badgeBg = '';
                let badgeColor = '';
                let badgeIcon = '';
                if (cardStatus === 'menunggu') {
                  badgeText = 'Menunggu Persetujuan';
                  badgeBg = 'bg-yellow-50';
                  badgeColor = 'text-yellow-700';
                  badgeIcon = '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><polyline points="12 7 12 12 15 15"></polyline></svg>';
                } else if (cardStatus === 'terjadwal') {
                  badgeText = 'Terjadwal';
                  badgeBg = 'bg-blue-50';
                  badgeColor = 'text-blue-700';
                  badgeIcon = '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>';
                } else if (cardStatus === 'selesai' || p.statusKaprodi === 'disetujui') {
                  cardStatus = 'selesai';
                  badgeText = 'Selesai';
                  badgeBg = 'bg-emerald-50';
                  badgeColor = 'text-emerald-700';
                  badgeIcon = '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>';
                } else if (cardStatus === 'ditolak') {
                  badgeText = 'Ditolak';
                  badgeBg = 'bg-red-50';
                  badgeColor = 'text-red-700';
                  badgeIcon = '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>';
                }
            %>
            <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden shadow-sm card-hover" 
                 data-card 
                 data-status="<%= cardStatus %>"
                 data-search="<%= ((p.nama || p.pemohonId?.name || '') + ' ' + (p.judul_karya_akhir || '') + ' ' + (p.nim || p.pemohonId?.profile?.nim || '')).toLowerCase() %>"
                 data-prodi="<%= p.program_studi || p.pemohonId?.profile?.programStudi || '' %>">
              <div class="p-6">
                <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
                  <div class="flex-1">
                    <div class="flex flex-wrap items-center gap-3 mb-1">
                      <h3 class="text-base font-bold text-gray-800"><%= p.judul_karya_akhir %></h3>
                      <span class="status-badge <%= badgeBg %> <%= badgeColor %>" data-status-badge>
                        <%- badgeIcon %>
                        <%= badgeText %>
                      </span>
                    </div>
                    <p class="text-sm font-semibold text-blue-700 mb-3"><%= p.nama || p.pemohonId?.name || '-' %></p>

                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-x-4 gap-y-2.5">
                      <div class="meta-chip flex items-center gap-2 text-sm">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><rect x="2" y="5" width="20" height="14" rx="2"></rect><line x1="2" y1="10" x2="22" y2="10"></line></svg>
                        <span class="text-gray-400">NIM</span><span class="font-semibold text-gray-700"><%= p.nim || p.pemohonId?.profile?.nim || '-' %></span>
                      </div>
                      <div class="meta-chip flex items-center gap-2 text-sm">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
                        <span class="text-gray-400">Prodi</span><span class="font-semibold text-gray-700"><%= p.program_studi || p.pemohonId?.programStudi || p.pemohonId?.profile?.programStudi || '-' %></span>
                      </div>
                      <div class="meta-chip flex items-center gap-2 text-sm">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                        <span class="text-gray-400">Pembimbing</span><span class="font-semibold text-gray-700"><%= p.dosenPembimbingId?.name || p.dosenPembimbing || '-' %></span>
                      </div>
                      <div class="meta-chip flex items-center gap-2 text-sm">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                        <span class="text-gray-400">Diajukan</span><span class="font-semibold text-gray-700"><%= new Date(p.tanggalDiajukan).toLocaleDateString('id-ID', {day: '2-digit', month: 'long', year: 'numeric'}) %></span>
                      </div>
                      <div class="meta-chip flex items-center gap-2 text-sm">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="9" y1="13" x2="15" y2="13"></line></svg>
                        <span class="text-gray-400">Jenis</span><span class="font-semibold text-gray-700">
                          <%= p.jenis_sidang === 'seminar_proposal' ? 'Seminar Proposal' : (p.jenis_sidang === 'kolokium' ? 'Kolokium' : p.jenis_sidang) %>
                        </span>
                      </div>
                    </div>

                    <!-- Lampiran -->
                    <div class="flex flex-wrap gap-2 mt-4">
                      <% if (p.file_draft_karya_akhir) { %>
                        <a href="<%= p.file_draft_karya_akhir.startsWith('http') ? p.file_draft_karya_akhir : backendBaseUrl + '/' + p.file_draft_karya_akhir.replace(/\\/g, '/') %>" target="_blank" class="flex items-center gap-2 text-xs font-medium text-gray-600 bg-gray-50 hover:bg-gray-100 border border-gray-200 rounded-lg px-3 py-1.5 transition">
                          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
                          Draft Karya Akhir
                        </a>
                      <% } %>
                    </div>
                  </div>

                  <div class="flex flex-col gap-2 shrink-0 w-full md:w-auto" data-action-area>
                    <% 
                      let isJadwalSelesai = false;
                      if (p.jadwal && p.jadwal.tanggal && p.jadwal.jamSelesai) {
                        const jadwalDate = new Date(p.jadwal.tanggal);
                        const parts = p.jadwal.jamSelesai.split(':');
                        if (parts.length >= 2) {
                          jadwalDate.setHours(parseInt(parts[0], 10), parseInt(parts[1], 10), 0, 0);
                          if (new Date() > jadwalDate) {
                            isJadwalSelesai = true;
                          }
                        }
                      }
                    %>
                    <% if (cardStatus === 'menunggu') { %>
                      <button type="button" data-id="<%= p._id %>" class="btn-setujui px-4 py-2 bg-blue-600 hover:bg-blue-700 rounded-lg text-sm font-semibold text-white transition flex items-center justify-center gap-1.5 shadow-md shadow-blue-200">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                        Setujui & Jadwalkan
                      </button>

                    <% } else if (cardStatus === 'ditolak' || ((cardStatus === 'terjadwal' || cardStatus === 'selesai') && !isJadwalSelesai)) { %>
                      <button type="button" data-id="<%= p._id %>" data-jadwal="<%= encodeURIComponent(JSON.stringify(p.jadwal || {})) %>" data-judul="<%= encodeURIComponent(p.judul_karya_akhir || '') %>" class="btn-edit-jadwal px-4 py-2 bg-white hover:bg-blue-50 border border-blue-200 rounded-lg text-sm font-semibold text-blue-700 transition flex items-center justify-center gap-1.5">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                        Edit Jadwal
                      </button>
                    <% } %>
                  </div>
                </div>

                <!-- Info Tanda Tangan Dosen -->
                <div class="mt-4 pt-4 border-t border-gray-100">
                  <div class="flex items-start gap-3 rounded-xl border border-blue-200 bg-blue-50 p-3.5">
                    <span class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0" style="background:#dbeafe; color:#1e40af;">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                    </span>
                    <div>
                      <h4 class="text-xs font-bold text-blue-900 mb-0.5">Sudah ditandatangani Dosen Pembimbing</h4>
                      <p class="text-xs text-blue-700">Ditandatangani pada <%= p.tanggalTandatangan ? new Date(p.tanggalTandatangan).toLocaleString('id-ID', {day: '2-digit', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit'}) + ' WIB' : '-' %></p>
                    </div>
                  </div>
                </div>

                <div class="info-sidang-slot">
                  <% if (cardStatus === 'terjadwal' && p.jadwal) { %>
                    <div class="mt-4 pt-4 border-t border-gray-100">
                      <div class="rounded-xl border border-gray-200 overflow-hidden">
                        <div class="px-4 py-2.5 flex items-center gap-2" style="background: linear-gradient(135deg, #1e40af 0%, #2563eb 100%);">
                          <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                          <h4 class="text-xs font-bold text-white tracking-wide">INFORMASI SIDANG</h4>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-3 p-4" style="background:#f8fafc;">
                          <div class="bg-white rounded-lg p-3 border border-gray-200">
                            <div class="flex items-center gap-2 mb-1.5">
                              <span class="w-7 h-7 rounded-lg flex items-center justify-center shrink-0" style="background:#e8effc; color:#1e40af;">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                              </span>
                              <span class="text-[11px] font-bold uppercase tracking-wide text-gray-500">Jadwal Sidang</span>
                            </div>
                            <p class="text-sm text-gray-800"><span class="text-gray-400">Tanggal:</span> <span class="font-semibold"><%= p.jadwal.tanggal ? new Date(p.jadwal.tanggal).toLocaleDateString('id-ID') : '-' %></span></p>
                            <p class="text-sm text-gray-800"><span class="text-gray-400">Pukul:</span> <span class="font-semibold"><%= p.jadwal.jamMulai || '-' %> - <%= p.jadwal.jamSelesai || '-' %> WIB</span></p>
                            <% if (p.jadwal.teknik === 'offline') { %>
                              <p class="text-sm text-gray-800"><span class="text-gray-400">Ruang:</span> <span class="font-semibold"><%= p.jadwal.ruang || '-' %></span></p>
                            <% } %>
                          </div>
                          <div class="bg-white rounded-lg p-3 border border-gray-200">
                            <div class="flex items-center gap-2 mb-1.5">
                              <span class="w-7 h-7 rounded-lg flex items-center justify-center shrink-0" style="background:#e8effc; color:#1e40af;">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                              </span>
                              <span class="text-[11px] font-bold uppercase tracking-wide text-gray-500">Tim Penguji</span>
                            </div>
                            <div>
                              <% if (p.jadwal.penguji && p.jadwal.penguji.length > 0) { %>
                                <% p.jadwal.penguji.forEach((pg, idx) => { %>
                                  <p class="text-sm text-gray-800 font-medium"><%= idx+1 %>. <%= pg.nama %> <span class="text-gray-400 font-normal">(<%= pg.peran %>)</span></p>
                                <% }) %>
                              <% } else { %>
                                <p class="text-sm text-gray-400">Belum ada penguji</p>
                              <% } %>
                            </div>
                          </div>
                          <div class="bg-white rounded-lg p-3 border border-gray-200">
                            <div class="flex items-center gap-2 mb-1.5">
                              <span class="w-7 h-7 rounded-lg flex items-center justify-center shrink-0" style="background:#e8effc; color:#1e40af;">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9"></path></svg>
                              </span>
                              <span class="text-[11px] font-bold uppercase tracking-wide text-gray-500">Teknik Sidang</span>
                            </div>
                            <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-semibold bg-emerald-50 text-emerald-700 border border-emerald-200">
                              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
                              <%= p.jadwal.teknik === 'online' ? 'Sidang Daring' : 'Sidang Luring' %>
                            </span>
                            <% if (p.jadwal.teknik === 'online') { %>
                              <p class="text-gray-500 mt-1.5 text-xs truncate"><%= p.jadwal.linkMeeting || '-' %></p>
                            <% } %>
                          </div>
                        </div>
                      </div>
                    </div>
                  <% } else if (cardStatus === 'ditolak') { %>
                    <div class="mt-4 pt-4 border-t border-gray-100">
                      <div class="flex items-start gap-3 rounded-xl border border-red-200 bg-red-50 p-3.5">
                        <span class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0" style="background:#fee2e2; color:#991b1b;">
                          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        </span>
                        <div>
                          <p class="text-sm text-red-800 font-semibold">Alasan Penolakan</p>
                          <p class="text-sm text-red-700 mt-0.5"><%= p.alasanTolak || p.alasanTolakKaprodi || 'Ditolak' %></p>
                        </div>
                      </div>
                    </div>
                  <% } else if (cardStatus === 'selesai') { %>
                    <div class="mt-4 pt-4 border-t border-gray-100">
                      <div class="flex items-start gap-3 rounded-xl border border-emerald-200 bg-emerald-50 p-3.5">
                        <span class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0" style="background:#d1fae5; color:#065f46;">
                          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        </span>
                        <div>
                          <p class="text-sm text-emerald-800 font-semibold">Sidang telah dilaksanakan / Disetujui</p>
                        </div>
                      </div>
                    </div>
                  <% } %>
                </div>
              </div>
            </div>
            <% }) %>
          <% } else { %>
            <div class="flex flex-col items-center justify-center py-12 text-center bg-white rounded-2xl border border-gray-200">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-gray-300 mb-3"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
              <p class="text-sm font-semibold text-gray-500">Tidak ada pengajuan</p>
            </div>
          <% } %>
        </div>

        </div>
      </div>
    </div>
  </div>

  <!-- ══════════ MODAL: SETUJUI & JADWALKAN ══════════ -->
  <div class="modal-overlay" id="modalSetujui">
    <div class="modal-box bg-white rounded-2xl shadow-xl w-full max-w-2xl max-h-[90vh] overflow-y-auto">
      <div class="px-6 py-4 flex items-center justify-between sticky top-0 z-10" style="background: linear-gradient(135deg, #1e40af 0%, #2563eb 100%);">
        <div>
          <span class="text-white font-bold text-sm tracking-wide">SETUJUI & JADWALKAN SIDANG</span>
          <p class="text-blue-200 text-xs mt-0.5" id="modalSetujuiSubtitle">Lengkapi detail pelaksanaan sidang</p>
        </div>
        <button type="button" class="modal-close text-white/80 hover:text-white" data-modal="modalSetujui">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>

      <form id="formSetujui" class="px-6 py-6 space-y-5" method="POST">
        <!-- Tanggal & Jam -->
        <div>
          <p class="text-xs font-bold uppercase tracking-wide text-gray-500 mb-2">Jadwal</p>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">Tanggal Sidang</label>
              <input type="date" name="tanggal" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">Jam Mulai</label>
              <input type="time" name="jam_mulai" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">Jam Selesai</label>
              <input type="time" name="jam_selesai" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
          </div>
        </div>

        <!-- Teknik Sidang -->
        <div>
          <p class="text-xs font-bold uppercase tracking-wide text-gray-500 mb-2">Teknik Sidang</p>
          <div class="flex gap-3 mb-3">
            <label class="flex-1 flex items-center gap-2 border border-gray-300 rounded-lg px-3 py-2.5 cursor-pointer has-[:checked]:border-blue-500 has-[:checked]:bg-blue-50 has-[:checked]:ring-1 has-[:checked]:ring-blue-500 transition">
              <input type="radio" name="teknik" value="offline" checked class="accent-blue-600">
              <span class="text-sm font-medium text-gray-700">Offline (Tatap Muka)</span>
            </label>
            <label class="flex-1 flex items-center gap-2 border border-gray-300 rounded-lg px-3 py-2.5 cursor-pointer has-[:checked]:border-blue-500 has-[:checked]:bg-blue-50 has-[:checked]:ring-1 has-[:checked]:ring-blue-500 transition">
              <input type="radio" name="teknik" value="online" class="accent-blue-600">
              <span class="text-sm font-medium text-gray-700">Online (Daring)</span>
            </label>
          </div>
          <div id="fieldOffline">
            <label class="block text-xs font-medium text-gray-600 mb-1">Ruang Sidang</label>
            <input type="text" name="ruang" placeholder="Contoh: Ruang Seminar A101" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          </div>
          <div id="fieldOnline" class="hidden">
            <label class="block text-xs font-medium text-gray-600 mb-1">Link Meeting (Zoom / Google Meet)</label>
            <input type="text" name="link_meeting" placeholder="https://zoom.us/j/..." class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          </div>
        </div>

        <!-- Tim Penguji -->
        <div>
          <div class="flex items-center justify-between mb-2">
            <p class="text-xs font-bold uppercase tracking-wide text-gray-500">Tim Penguji</p>
            <button type="button" id="btnAddPenguji" class="text-xs font-semibold text-blue-600 hover:text-blue-700 flex items-center gap-1">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 4v16m8-8H4"></path></svg>
              Tambah Penguji
            </button>
          </div>
          <div id="pengujiList" class="space-y-2"></div>
        </div>

        <div class="flex justify-end gap-3 pt-2 border-t border-gray-100">
          <button type="button" class="modal-close px-5 py-2 rounded-lg border border-gray-300 text-gray-600 text-sm font-semibold hover:bg-gray-50 transition" data-modal="modalSetujui">Batal</button>
          <button type="submit" class="px-5 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold transition shadow-md shadow-blue-200">Simpan & Setujui</button>
        </div>
      </form>
    </div>
  </div>

  <!-- ══════════ MODAL: TOLAK PENGAJUAN ══════════ -->
  <div class="modal-overlay" id="modalTolak">
    <div class="modal-box bg-white rounded-2xl shadow-xl w-full max-w-md overflow-hidden">
      <div class="px-6 py-4 flex items-center justify-between" style="background: linear-gradient(135deg, #991b1b 0%, #dc2626 100%);">
        <div>
          <span class="text-white font-bold text-sm tracking-wide">TOLAK PENGAJUAN</span>
          <p class="text-red-200 text-xs mt-0.5" id="modalTolakSubtitle">Beri alasan agar pemohon bisa merevisi</p>
        </div>
        <button type="button" class="modal-close text-white/80 hover:text-white" data-modal="modalTolak">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>
      <form id="formTolak" class="px-6 py-6 space-y-4" method="POST">
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1.5">Alasan Penolakan <span class="text-red-500">*</span></label>
          <textarea name="alasan" rows="4" required placeholder="Contoh: Draft karya akhir perlu direvisi dan disetujui ulang oleh dosen pembimbing."
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-red-400 resize-none"></textarea>
        </div>
        <div class="flex justify-end gap-3 pt-2 border-t border-gray-100">
          <button type="button" class="modal-close px-5 py-2 rounded-lg border border-gray-300 text-gray-600 text-sm font-semibold hover:bg-gray-50 transition" data-modal="modalTolak">Batal</button>
          <button type="submit" class="px-5 py-2 rounded-lg bg-red-600 hover:bg-red-700 text-white text-sm font-semibold transition shadow-md shadow-red-200">Tolak Pengajuan</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    // ── Buka/tutup modal ──
    let activeCard = null;

    function openModal(id) {
      document.getElementById(id).classList.add('active');
    }
    function closeModal(id) {
      document.getElementById(id).classList.remove('active');
    }
    document.querySelectorAll('.modal-close').forEach(btn => {
      btn.addEventListener('click', () => closeModal(btn.dataset.modal));
    });
    document.querySelectorAll('.modal-overlay').forEach(overlay => {
      overlay.addEventListener('click', (e) => {
        if (e.target === overlay) closeModal(overlay.id);
      });
    });

    document.querySelectorAll('.btn-setujui').forEach(btn => {
      btn.addEventListener('click', () => {
        activeCard = btn.closest('[data-card]');
        const proposalId = btn.getAttribute('data-id');
        document.getElementById('formSetujui').action = '/dashboard/admin/kelola-pengajuan/' + proposalId + '/jadwalkan';
        const judul = activeCard.querySelector('h3').textContent.trim();
        document.getElementById('modalSetujuiSubtitle').textContent = judul;
        
        document.getElementById('formSetujui').reset();
        resetPengujiDefault();
        const rdoOffline = document.querySelector('#formSetujui input[name="teknik"][value="offline"]');
        if (rdoOffline) { rdoOffline.checked = true; rdoOffline.dispatchEvent(new Event('change')); }
        
        openModal('modalSetujui');
      });
    });


    document.querySelectorAll('.btn-edit-jadwal').forEach(btn => {
      btn.addEventListener('click', () => {
        activeCard = btn.closest('[data-card]');
        const proposalId = btn.getAttribute('data-id');
        document.getElementById('formSetujui').action = '/dashboard/admin/kelola-pengajuan/' + proposalId + '/jadwalkan';
        const judul = activeCard.querySelector('h3').textContent.trim();
        document.getElementById('modalSetujuiSubtitle').textContent = judul;
        
        const jadwalRaw = btn.getAttribute('data-jadwal');
        if (jadwalRaw) {
          try {
            const jadwal = JSON.parse(decodeURIComponent(jadwalRaw));
            if (jadwal.tanggal) document.querySelector('#formSetujui input[name="tanggal"]').value = jadwal.tanggal.split('T')[0];
            if (jadwal.jamMulai) document.querySelector('#formSetujui input[name="jam_mulai"]').value = jadwal.jamMulai;
            if (jadwal.jamSelesai) document.querySelector('#formSetujui input[name="jam_selesai"]').value = jadwal.jamSelesai;
            
            if (jadwal.teknik) {
              const rdo = document.querySelector(`#formSetujui input[name="teknik"][value="${jadwal.teknik}"]`);
              if (rdo) { rdo.checked = true; rdo.dispatchEvent(new Event('change')); }
            }
            if (jadwal.ruang) document.querySelector('#formSetujui input[name="ruang"]').value = jadwal.ruang;
            if (jadwal.linkMeeting) document.querySelector('#formSetujui input[name="link_meeting"]').value = jadwal.linkMeeting;
            
            if (jadwal.penguji && jadwal.penguji.length > 0) {
              pengujiList.innerHTML = '';
              jadwal.penguji.forEach(penguji => addPengujiRow(penguji.nama, penguji.peran));
            } else {
              resetPengujiDefault();
            }
          } catch(e) { console.error(e); resetPengujiDefault(); }
        }
        
        openModal('modalSetujui');
      });
    });

    // ── Toggle field offline/online ──
    document.querySelectorAll('input[name="teknik"]').forEach(radio => {
      radio.addEventListener('change', () => {
        const isOnline = document.querySelector('input[name="teknik"]:checked').value === 'online';
        document.getElementById('fieldOffline').classList.toggle('hidden', isOnline);
        document.getElementById('fieldOnline').classList.toggle('hidden', !isOnline);
      });
    });

    // ── Tim Penguji dinamis ──
    const pengujiList = document.getElementById('pengujiList');
    let pengujiCount = 0;

    function addPengujiRow(nama = '', peran = 'Anggota') {
      pengujiCount++;
      const row = document.createElement('div');
      row.className = 'flex items-center gap-2';
      row.innerHTML = `
        <input type="text" name="penguji_nama[]" value="${nama}" placeholder="Nama dosen penguji" required
          class="flex-1 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
        <select name="penguji_peran[]" class="border border-gray-300 rounded-lg px-2 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          <option value="Ketua" ${peran === 'Ketua' ? 'selected' : ''}>Ketua</option>
          <option value="Anggota" ${peran === 'Anggota' ? 'selected' : ''}>Anggota</option>
        </select>
        <button type="button" class="remove-penguji shrink-0 w-8 h-8 rounded-lg flex items-center justify-center text-gray-400 hover:text-red-500 hover:bg-red-50 transition">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      `;
      row.querySelector('.remove-penguji').addEventListener('click', () => row.remove());
      pengujiList.appendChild(row);
    }

    document.getElementById('btnAddPenguji').addEventListener('click', () => addPengujiRow());

    function resetPengujiDefault() {
      pengujiList.innerHTML = '';
      addPengujiRow('', 'Ketua');
      addPengujiRow('', 'Anggota');
    }
    resetPengujiDefault();

    // ── Update ringkasan statistik ──
    function updateStats() {
      const cards = document.querySelectorAll('[data-card]');
      const counts = { menunggu: 0, terjadwal: 0, selesai: 0, ditolak: 0 };
      cards.forEach(c => { if (counts[c.dataset.status] !== undefined) counts[c.dataset.status]++; });
      document.getElementById('statTotal').textContent = cards.length;
      document.getElementById('statMenunggu').textContent = counts.menunggu;
      document.getElementById('statTerjadwal').textContent = counts.terjadwal;
      document.getElementById('statSelesai').textContent = counts.selesai;
      document.getElementById('statDitolak').textContent = counts.ditolak;
    }

    // Normal form submission will happen via POST method

    // ── Filter Data ──
    const searchInput = document.getElementById('searchInput');
    const filterStatus = document.getElementById('filterStatus');
    const filterProdi = document.getElementById('filterProdi');

    function applyFilters() {
      const q = searchInput ? searchInput.value.trim().toLowerCase() : '';
      const st = filterStatus ? filterStatus.value : '';
      const pr = filterProdi ? filterProdi.value : '';

      document.querySelectorAll('[data-card]').forEach(card => {
        const matchQ = !q || (card.dataset.search || '').includes(q);
        const matchSt = !st || card.dataset.status === st;
        const matchPr = !pr || card.dataset.prodi === pr;
        card.style.display = (matchQ && matchSt && matchPr) ? '' : 'none';
      });
    }

    if (searchInput) searchInput.addEventListener('input', applyFilters);
    if (filterStatus) filterStatus.addEventListener('change', applyFilters);
    if (filterProdi) filterProdi.addEventListener('change', applyFilters);

    updateStats();
      // Set minimal tanggal jadwal sidang ke besok
    const besok = new Date();
    besok.setDate(besok.getDate() + 1);
    const minDateStr = besok.toISOString().split('T')[0];
    document.querySelectorAll('input[type="date"][name="tanggal"]').forEach(input => {
      input.setAttribute('min', minDateStr);
    });
      // Set minimal tanggal jadwal sidang ke besok
    const besok = new Date();
    besok.setDate(besok.getDate() + 1);
    const minDateStr = besok.toISOString().split('T')[0];
    document.querySelectorAll('input[type="date"][name="tanggal"]').forEach(input => {
      input.setAttribute('min', minDateStr);
    });
  </script>

</body>
</html>
