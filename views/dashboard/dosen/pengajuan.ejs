<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pengajuan Menunggu Tanda Tangan - PPSU</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    .status-badge {
      display: inline-flex; align-items: center; gap: 0.3rem;
      padding: 0.3rem 0.75rem; border-radius: 9999px;
      font-size: 0.72rem; font-weight: 600; letter-spacing: 0.01em;
    }
    .status-menunggu   { background: #fef3c7; color: #92400e; }
    .status-ditandatangani { background: #dbeafe; color: #1e40af; }

    .card-hover { transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease; }
    .card-hover:hover { transform: translateY(-2px); box-shadow: 0 10px 32px rgba(15, 23, 42, 0.07); border-color: #dbe4f0; }
    .meta-chip svg { color: #1e40af; }
  </style>
</head>
<body class="bg-gray-100">

  <%- include('../../partials/sidebar_dosen', { user: locals.user, currentPath: locals.currentPath }) %>

  <div class="min-h-screen">
    <!-- TOP BAR -->
    <div class="bg-white border-b border-gray-200 px-6 py-4 flex items-center justify-between" style="padding-left: 64px;">
      <div class="flex items-center gap-3 pl-8">
        <img src="/images/paramadinalogo.svg" alt="PPSU" class="h-7 object-contain">
        <div class="w-px h-10 bg-gray-200"></div>
        <div class="flex flex-col leading-tight">
          <span class="text-sm font-bold text-gray-800">Pengajuan Menunggu Tanda Tangan</span>
          <span class="text-[10px] font-semibold text-blue-600 uppercase tracking-wider">
            Panel Dosen Pembimbing
          </span>
        </div>
      </div>

      <div class="flex items-center pr-2">
        <a href="/dashboard/dosen"
           class="flex items-center gap-2.5 bg-blue-50 hover:bg-blue-100 border border-blue-100 rounded-full pl-2 pr-4 py-1.5 transition-colors shadow-sm">
          <span class="w-6 h-6 rounded-full bg-blue-600 flex items-center justify-center shrink-0">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="7" height="9" x="3" y="3" rx="1"></rect>
              <rect width="7" height="5" x="14" y="3" rx="1"></rect>
              <rect width="7" height="9" x="14" y="12" rx="1"></rect>
              <rect width="7" height="5" x="3" y="16" rx="1"></rect>
            </svg>
          </span>
          <span class="text-xs font-semibold text-blue-700 whitespace-nowrap">Dashboard</span>
        </a>
      </div>
    </div>

    <div class="px-6 py-8" style="padding-left: 64px;">
      <div class="max-w-[1600px] mx-auto">

        <!-- Alert -->
        <% if (locals.success_msg && success_msg.length > 0) { %>
          <div class="bg-green-50 border border-green-200 rounded-lg px-4 py-3 mb-4 text-green-700 text-sm flex items-center gap-2">
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <%= success_msg %>
          </div>
        <% } %>
        <% if (locals.error_msg && error_msg.length > 0) { %>
          <div class="bg-red-50 border border-red-200 rounded-lg px-4 py-3 mb-4 text-red-600 text-sm flex items-center gap-2">
            <%= error_msg %>
          </div>
        <% } %>

        <%
          const total = pengajuanList.length;
          const totalMenunggu = pengajuanList.filter(p => p.status === 'menunggu').length;
          const totalDitandatangani = pengajuanList.filter(p => p.status === 'ditandatangani').length;
        %>

        <!-- Ringkasan Statistik -->
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-6">
          <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-4 flex items-center gap-3">
            <span class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0" style="background:#e8effc; color:#1e40af;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
            </span>
            <div><p id="statTotal" class="text-lg font-bold text-gray-800"><%= total %></p><p class="text-[11px] font-medium text-gray-400">Total Mahasiswa Bimbingan</p></div>
          </div>
          <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-4 flex items-center gap-3">
            <span class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0" style="background:#fef3c7; color:#92400e;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><polyline points="12 7 12 12 15 15"></polyline></svg>
            </span>
            <div><p id="statMenunggu" class="text-lg font-bold text-gray-800"><%= totalMenunggu %></p><p class="text-[11px] font-medium text-gray-400">Menunggu Tanda Tangan</p></div>
          </div>
          <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-4 flex items-center gap-3">
            <span class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0" style="background:#dbeafe; color:#1e40af;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            </span>
            <div><p id="statDitandatangani" class="text-lg font-bold text-gray-800"><%= totalDitandatangani %></p><p class="text-[11px] font-medium text-gray-400">Sudah Ditandatangani</p></div>
          </div>
        </div>

        <!-- Filter / Pencarian -->
        <div class="bg-white rounded-2xl border border-gray-200 p-4 mb-6 shadow-sm">
          <div class="flex flex-col sm:flex-row gap-3 items-center justify-between">
            <div class="flex items-center gap-3 w-full sm:w-auto">
              <div class="relative flex-1 sm:flex-none">
                <input type="text" id="searchInput" placeholder="Cari nama, judul, atau NIM..."
                       class="w-full sm:w-72 pl-10 pr-4 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                <svg class="absolute left-3 top-2.5 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                </svg>
              </div>
              <select id="statusFilter" class="px-3 py-2 border border-gray-300 rounded-lg text-sm text-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500">
                <option value="">Semua Status</option>
                <option value="menunggu">Menunggu Tanda Tangan</option>
                <option value="ditandatangani">Sudah Ditandatangani</option>
              </select>
            </div>
          </div>
        </div>

        <!-- Daftar Pengajuan -->
        <div class="space-y-4" id="cardList">

          <% if (pengajuanList.length === 0) { %>
            <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-10 text-center text-sm text-gray-400">
              Belum ada pengajuan.
            </div>
          <% } %>

          <% pengajuanList.forEach(function(p) { %>
            <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden shadow-sm card-hover"
                 data-card data-status="<%= p.status %>"
                 data-search="<%= (p.nama + ' ' + p.judul_karya_akhir + ' ' + p.nim).toLowerCase() %>">
              <div class="p-6">
                <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
                  <div class="flex-1">
                    <div class="flex flex-wrap items-center gap-3 mb-1">
                      <h3 class="text-base font-bold text-gray-800"><%= p.judul_karya_akhir %></h3>

                      <% if (p.status === 'menunggu') { %>
                        <span class="status-badge status-menunggu">
                          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><polyline points="12 7 12 12 15 15"></polyline></svg>
                          Menunggu Tanda Tangan
                        </span>
                      <% } else { %>
                        <span class="status-badge status-ditandatangani">
                          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                          Menunggu Persetujuan UPPS
                        </span>
                      <% } %>
                    </div>
                    <p class="text-sm font-semibold text-blue-700 mb-3"><%= p.nama %></p>

                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-4 gap-y-2.5">
                      <div class="meta-chip flex items-center gap-2 text-sm">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><rect x="2" y="5" width="20" height="14" rx="2"></rect><line x1="2" y1="10" x2="22" y2="10"></line></svg>
                        <span class="text-gray-400">NIM</span><span class="font-semibold text-gray-700"><%= p.nim %></span>
                      </div>
                      <div class="meta-chip flex items-center gap-2 text-sm">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
                        <span class="text-gray-400">Prodi</span><span class="font-semibold text-gray-700"><%= p.program_studi %></span>
                      </div>
                      <div class="meta-chip flex items-center gap-2 text-sm">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                        <span class="text-gray-400">Diajukan</span><span class="font-semibold text-gray-700"><%= p.tanggalDiajukan ? new Date(p.tanggalDiajukan).toLocaleDateString('id-ID', { day: '2-digit', month: 'long', year: 'numeric' }) : '-' %></span>
                      </div>
                      <div class="meta-chip flex items-center gap-2 text-sm">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="9" y1="13" x2="15" y2="13"></line></svg>
                        <span class="text-gray-400">Jenis</span><span class="font-semibold text-gray-700"><%= p.jenis_karya || 'Seminar Proposal' %></span>
                      </div>
                    </div>

                    <!-- Lampiran -->
                    <% if (p.lampiran && p.lampiran.length > 0) { %>
                      <div class="flex flex-wrap gap-2 mt-4">
                        <% p.lampiran.forEach(function(file) { %>
                          <a href="<%= file.url %>" target="_blank" class="flex items-center gap-2 text-xs font-medium text-gray-600 bg-gray-50 hover:bg-gray-100 border border-gray-200 rounded-lg px-3 py-1.5 transition">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
                            <%= file.nama %>
                          </a>
                        <% }); %>
                      </div>
                    <% } %>
                  </div>

                  <% if (p.status === 'menunggu') { %>
                    <div class="flex flex-col sm:flex-row gap-2 shrink-0 w-full md:w-auto" data-action-area>
                      <a href="/dashboard/dosen/pengajuan/<%= p._id %>/detail" class="px-4 py-2 bg-blue-600 hover:bg-blue-700 rounded-lg text-sm font-semibold text-white transition flex items-center justify-center gap-1.5 shadow-md shadow-blue-200 w-full sm:w-auto">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5z"></path></svg>
                        Tanda Tangani
                      </a>
                      <button type="button" data-id="<%= p._id %>" class="btn-tolak px-4 py-2 bg-white hover:bg-red-50 border border-red-200 rounded-lg text-sm font-semibold text-red-600 transition flex items-center justify-center gap-1.5 w-full sm:w-auto">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                        Tolak
                      </button>
                    </div>
                  <% } %>
                </div>

                <% if (p.status === 'ditandatangani') { %>
                  <%
                    const isRecentlySigned = p.signedAt &&
                      (Date.now() - new Date(p.signedAt).getTime()) < (24 * 60 * 60 * 1000);
                  %>
                  <div class="mt-4 pt-4 border-t border-gray-100">
                    <% if (isRecentlySigned) { %>
                      <div class="flex items-start gap-3 rounded-xl border border-green-200 bg-green-50 p-3.5 mb-3">
                        <span class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0" style="background:#dcfce7; color:#16a34a;">
                          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        </span>
                        <div>
                          <p class="text-sm text-green-800 font-semibold">Pengajuan berhasil ditandatangani</p>
                          <p class="text-sm text-green-700 mt-0.5">Ditandatangani pada <%= p.tanggalTandatangan %></p>
                        </div>
                      </div>
                    <% } %>
                    <div class="flex items-start gap-3 rounded-xl border border-blue-200 bg-blue-50 p-3.5">
                      <span class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0" style="background:#dbeafe; color:#1e40af;">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                      </span>
                      <div>
                        <p class="text-sm text-blue-800 font-semibold">Sudah ditandatangani, diteruskan ke UPPS</p>
                        <p class="text-sm text-blue-700 mt-0.5">Ditandatangani pada <%= p.tanggalTandatangan %></p>
                      </div>
                    </div>
                  </div>
                <% } %>
              </div>
            </div>
          <% }); %>

        </div>
      </div>
    </div>
  </div>

  <!-- Modal Tolak -->
  <div id="modalTolak" class="fixed inset-0 z-50 flex items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity duration-300">
    <div class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm" onclick="closeModal('modalTolak')"></div>
    <div class="bg-white rounded-2xl w-full max-w-md shadow-2xl relative transform scale-95 transition-transform duration-300">
      <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-red-50 flex items-center justify-center shrink-0">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </div>
          <div>
            <h3 class="text-base font-bold text-gray-900">Tolak Pengajuan</h3>
            <p class="text-xs text-gray-500 font-medium line-clamp-1" id="modalTolakSubtitle">Loading...</p>
          </div>
        </div>
        <button onclick="closeModal('modalTolak')" class="text-gray-400 hover:text-gray-600 transition p-2 hover:bg-gray-50 rounded-lg">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>
      
      <form id="formTolak" method="POST" action="">
        <div class="p-6">
          <label class="block text-sm font-semibold text-gray-700 mb-2">Alasan Penolakan <span class="text-red-500">*</span></label>
          <textarea name="catatanDospem" required rows="4" 
                    class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none transition text-sm resize-none"
                    placeholder="Tuliskan alasan detail mengapa pengajuan ini ditolak..."></textarea>
          <p class="text-[11px] text-gray-500 mt-2 font-medium">Alasan ini akan dikirimkan ke mahasiswa untuk perbaikan.</p>
        </div>
        
        <div class="px-6 py-4 bg-gray-50 rounded-b-2xl border-t border-gray-100 flex items-center justify-end gap-3">
          <button type="button" onclick="closeModal('modalTolak')" class="px-5 py-2.5 text-sm font-semibold text-gray-700 bg-white border border-gray-300 hover:bg-gray-50 rounded-xl transition">
            Batal
          </button>
          <button type="submit" class="px-5 py-2.5 text-sm font-semibold text-white bg-red-600 hover:bg-red-700 rounded-xl transition shadow-md shadow-red-200">
            Tolak Pengajuan
          </button>
        </div>
      </form>
    </div>
  </div>

  <script>
    // Filter & pencarian sisi client (data sudah dirender dari server)
    const searchInput = document.getElementById('searchInput');
    const statusFilter = document.getElementById('statusFilter');
    const cards = document.querySelectorAll('#cardList [data-card]');

    function applyFilter() {
      const q = searchInput.value.trim().toLowerCase();
      const status = statusFilter.value;

      cards.forEach((card) => {
        const matchSearch = !q || card.dataset.search.includes(q);
        const matchStatus = !status || card.dataset.status === status;
        card.style.display = (matchSearch && matchStatus) ? '' : 'none';
      });
    }

    searchInput.addEventListener('input', applyFilter);
    statusFilter.addEventListener('change', applyFilter);

    function openModal(modalId) {
      const modal = document.getElementById(modalId);
      if(modal) {
        modal.classList.remove('opacity-0', 'pointer-events-none');
        modal.querySelector('.transform').classList.remove('scale-95');
      }
    }

    function closeModal(modalId) {
      const modal = document.getElementById(modalId);
      if(modal) {
        modal.classList.add('opacity-0', 'pointer-events-none');
        modal.querySelector('.transform').classList.add('scale-95');
      }
    }

    document.querySelectorAll('.btn-tolak').forEach(btn => {
      btn.addEventListener('click', () => {
        const activeCard = btn.closest('[data-card]');
        const proposalId = btn.getAttribute('data-id');
        document.getElementById('formTolak').action = '/dashboard/dosen/pengajuan/' + proposalId + '/tolak';
        const judul = activeCard.querySelector('h3').textContent.trim();
        document.getElementById('modalTolakSubtitle').textContent = judul;
        openModal('modalTolak');
      });
    });
  </script>

</body>
</html>
