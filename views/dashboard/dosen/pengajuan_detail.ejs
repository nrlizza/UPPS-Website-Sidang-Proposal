<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tanda Tangani Pengajuan - PPSU</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @keyframes spin { to { transform: rotate(360deg); } }
    .animate-spin { animation: spin 1s linear infinite; }
    #signatureCanvas { touch-action: none; cursor: crosshair; }
  </style>
</head>
<body class="bg-gray-100">

  <%- include('../../partials/sidebar_dosen', { user: locals.user, currentPath: locals.currentPath }) %>

  <div class="min-h-screen">

    <!-- TOP BAR -->
    <div class="bg-white border-b border-gray-200 px-6 py-4 flex items-center justify-between" style="padding-left: 64px;">
      <div class="flex items-center gap-3 pl-8">
        <img src="/images/paramadinalogo.svg" alt="PPSU" class="h-7 object-contain">
        <div class="w-px h-10 bg-gray-200"></div>
        <div class="flex flex-col leading-tight">
          <span class="text-sm font-bold text-gray-800">Tanda Tangani Pengajuan</span>
          <span class="text-[10px] font-semibold text-blue-600 uppercase tracking-wider">
            Panel Dosen Pembimbing
          </span>
        </div>
      </div>
      <a href="/dashboard/dosen/pengajuan" class="flex items-center gap-1.5 text-xs font-semibold text-gray-500 hover:text-blue-600 transition">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
        Kembali ke Daftar
      </a>
    </div>

    <div class="px-6 py-8" style="padding-left: 64px;">

      <% if (locals.success_msg && success_msg.length > 0) { %>
        <p class="text-green-600 text-sm bg-green-50 border border-green-200 rounded-lg px-4 py-3 mb-4">
          <%= success_msg %>
        </p>
      <% } %>
      <% if (locals.error_msg && error_msg.length > 0) { %>
        <p class="text-red-500 text-sm bg-red-50 border border-red-200 rounded-lg px-4 py-3 mb-4">
          <%= error_msg %>
        </p>
      <% } %>

      <form id="ttdDosenForm" action="/dashboard/dosen/pengajuan/<%= pengajuan._id %>/tanda-tangan" method="POST" class="bg-white rounded-xl border border-gray-200 overflow-hidden shadow-sm">

        <!-- Header -->
        <div class="px-6 py-4 border-b border-gray-100"
          style="background: linear-gradient(135deg, #1e40af 0%, #2563eb 100%);">
          <span class="text-white font-bold text-sm tracking-wide">DETAIL PENGAJUAN SIDANG</span>
          <p class="text-blue-200 text-xs mt-0.5">Tinjau data mahasiswa sebelum menandatangani</p>
        </div>

        <div class="px-8 py-6 space-y-6">

          <!-- Ringkasan Data (dari input pemohon) -->
          <div>
            <div class="flex items-center gap-2 mb-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1e40af" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5z"></path>
                <polyline points="14 2 14 8 20 8"></polyline>
              </svg>
              <p class="text-sm font-bold text-gray-800">Data Pendaftaran</p>
            </div>

            <div class="rounded-xl overflow-hidden" style="border: 1px solid #dbe4f0; background: #f8fafc;">
              <div class="flex items-start gap-3 px-4 py-3 border-b" style="border-color:#e6ecf5;">
                <span class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0" style="background:#e8effc; color:#1e40af;">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="9" y1="13" x2="15" y2="13"></line></svg>
                </span>
                <div class="flex-1 min-w-0 pt-0.5">
                  <p class="text-[11px] font-semibold uppercase tracking-wide" style="color:#7c8aa5;">Jenis Sidang</p>
                  <p class="text-sm font-medium text-gray-800 mt-0.5"><%= pengajuan.jenis_karya || 'Seminar Proposal' %></p>
                </div>
              </div>
              <div class="flex items-start gap-3 px-4 py-3 border-b" style="border-color:#e6ecf5;">
                <span class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0" style="background:#e8effc; color:#1e40af;">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                </span>
                <div class="flex-1 min-w-0 pt-0.5">
                  <p class="text-[11px] font-semibold uppercase tracking-wide" style="color:#7c8aa5;">Nama</p>
                  <p class="text-sm font-medium text-gray-800 mt-0.5"><%= pengajuan.nama %></p>
                </div>
              </div>
              <div class="flex items-start gap-3 px-4 py-3 border-b" style="border-color:#e6ecf5;">
                <span class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0" style="background:#e8effc; color:#1e40af;">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"></rect><line x1="2" y1="10" x2="22" y2="10"></line></svg>
                </span>
                <div class="flex-1 min-w-0 pt-0.5">
                  <p class="text-[11px] font-semibold uppercase tracking-wide" style="color:#7c8aa5;">NIM</p>
                  <p class="text-sm font-medium text-gray-800 mt-0.5"><%= pengajuan.nim %></p>
                </div>
              </div>
              <div class="flex items-start gap-3 px-4 py-3 border-b" style="border-color:#e6ecf5;">
                <span class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0" style="background:#e8effc; color:#1e40af;">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
                </span>
                <div class="flex-1 min-w-0 pt-0.5">
                  <p class="text-[11px] font-semibold uppercase tracking-wide" style="color:#7c8aa5;">Program Studi</p>
                  <p class="text-sm font-medium text-gray-800 mt-0.5"><%= pengajuan.program_studi %></p>
                </div>
              </div>
              <div class="flex items-start gap-3 px-4 py-3">
                <span class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0" style="background:#e8effc; color:#1e40af;">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="9" y1="13" x2="15" y2="13"></line><line x1="9" y1="17" x2="15" y2="17"></line></svg>
                </span>
                <div class="flex-1 min-w-0 pt-0.5">
                  <p class="text-[11px] font-semibold uppercase tracking-wide" style="color:#7c8aa5;">Judul Karya Akhir</p>
                  <p class="text-sm font-medium text-gray-800 mt-0.5 whitespace-pre-wrap leading-relaxed"><%= pengajuan.judul_karya_akhir %></p>
                </div>
              </div>
            </div>
          </div>

          <!-- Lampiran Dokumen -->
          <div class="border-t border-gray-100 pt-5">
            <div class="flex items-center gap-2 mb-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1e40af" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"></path>
              </svg>
              <p class="text-sm font-bold text-gray-800">Lampiran Dokumen</p>
            </div>
            <% if (pengajuan.file_draft_karya_akhir) { %>
              <a href="<%= pengajuan.file_draft_karya_akhir.startsWith('http') ? pengajuan.file_draft_karya_akhir : backendBaseUrl + '/' + pengajuan.file_draft_karya_akhir.replace(/\\/g, '/') %>" target="_blank" class="flex items-center gap-2 text-xs font-medium text-gray-600 bg-gray-50 hover:bg-gray-100 border border-gray-200 rounded-lg px-3 py-2 transition w-fit mb-2">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
                Draft Karya Akhir
              </a>
            <% } else { %>
              <p class="text-xs text-gray-400">Belum ada lampiran.</p>
            <% } %>
          </div>

          <!-- Tanda Tangan -->
          <div class="border-t border-gray-100 pt-5">
            <div class="flex items-center gap-2 mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1e40af" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5z"></path>
              </svg>
              <p class="text-sm font-bold text-gray-800">Tanda Tangan</p>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

              <!-- Kiri: Tanda Tangan Pemohon (sudah ada, read-only, dari data pemohon) -->
              <div>
                <p class="text-[11px] font-semibold uppercase tracking-wide mb-2" style="color: #7c8aa5;">Tanda Tangan Pemohon</p>
                <div class="border rounded-lg bg-white p-3 h-28 flex items-center justify-center" style="border-color: #dbe4f0;">
                  <% if (pengajuan.ttd_pemohon) { %>
                    <img id="ttdPemohonImg" src="<%= pengajuan.ttd_pemohon %>" alt="Tanda tangan pemohon" class="h-20">
                  <% } else { %>
                    <span id="ttdPemohonEmpty" class="text-xs text-gray-400">Tidak ada tanda tangan</span>
                  <% } %>
                </div>
              </div>

              <!-- Kanan: Slot Dosen Pembimbing, AKTIF (canvas) -->
              <div>
                <p class="text-[11px] font-semibold uppercase tracking-wide mb-2" style="color: #7c8aa5;">Mengetahui, Dosen Pembimbing</p>
                <div class="border rounded-lg overflow-hidden bg-white" style="border-color: #dbe4f0;">
                  <canvas id="signatureCanvas" class="w-full block bg-white" height="50"></canvas>
                </div>
                
                <div class="flex items-center justify-between mt-2">
                  <p class="text-xs text-gray-400">Tanda tangan di atas menggunakan mouse / jari.</p>
                  <button type="button" id="clearSignatureBtn"
                    class="shrink-0 ml-3 px-3 py-1.5 rounded text-xs font-medium border border-gray-300 text-gray-600 hover:bg-gray-50 transition">
                    Hapus &amp; Ulangi
                  </button>
                </div>
                <p id="signatureError" class="hidden text-red-500 text-xs mt-1">Tanda tangan wajib diisi.</p>
                <input type="hidden" id="ttd_dosen" name="ttd_dosen">
              </div>

            </div>
          </div>

          <p id="clientError" class="hidden text-red-500 text-xs bg-red-50 border border-red-200 rounded-lg px-3 py-2"></p>
        </div>

        <div class="flex justify-end gap-3 py-6 px-8 border-t border-gray-100">
          <a href="/dashboard/dosen/pengajuan"
             class="px-6 py-2 rounded-lg border border-gray-300 text-gray-600 text-sm font-semibold hover:bg-gray-50 transition">
            Batal
          </a>
          <button
            type="submit"
            id="submitBtn"
            class="px-6 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold transition shadow-md shadow-blue-200 flex items-center gap-2 disabled:opacity-70 disabled:cursor-not-allowed"
          >
            <svg id="submitSpinner" class="hidden animate-spin" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="2" x2="12" y2="6"></line>
              <line x1="12" y1="18" x2="12" y2="22"></line>
              <line x1="4.93" y1="4.93" x2="7.76" y2="7.76"></line>
              <line x1="16.24" y1="16.24" x2="19.07" y2="19.07"></line>
              <line x1="2" y1="12" x2="6" y2="12"></line>
              <line x1="18" y1="12" x2="22" y2="12"></line>
              <line x1="4.93" y1="19.07" x2="7.76" y2="16.24"></line>
              <line x1="16.24" y1="7.76" x2="19.07" y2="4.93"></line>
            </svg>
            <span id="submitBtnText">Simpan Tanda Tangan</span>
          </button>
        </div>

      </form>
    </div>
  </div>

  <script>
    // ── Signature Pad (dosen) ──
    const canvas = document.getElementById('signatureCanvas');
    const ctx = canvas.getContext('2d');
    const clearSignatureBtn = document.getElementById('clearSignatureBtn');
    const signatureError = document.getElementById('signatureError');
    const ttdInput = document.getElementById('ttd_dosen');
    let drawing = false;
    let hasSignature = false;

    function resizeCanvas() {
      const ratio = window.devicePixelRatio || 1;
      const rect = canvas.getBoundingClientRect();
      const prevData = hasSignature ? canvas.toDataURL() : null;

      canvas.width = rect.width * ratio;
      canvas.height = rect.height * ratio;
      ctx.scale(ratio, ratio);
      ctx.lineWidth = 2;
      ctx.lineCap = 'round';
      ctx.lineJoin = 'round';
      ctx.strokeStyle = '#1e3a6e';

      if (prevData) {
        const img = new Image();
        img.onload = () => ctx.drawImage(img, 0, 0, rect.width, rect.height);
        img.src = prevData;
      }
    }
    window.addEventListener('resize', resizeCanvas);
    resizeCanvas();

    function getPos(e) {
      const rect = canvas.getBoundingClientRect();
      const point = e.touches ? e.touches[0] : e;
      return { x: point.clientX - rect.left, y: point.clientY - rect.top };
    }
    function startDraw(e) {
      e.preventDefault();
      drawing = true; hasSignature = true;
      signatureError.classList.add('hidden');
      const pos = getPos(e);
      ctx.beginPath(); ctx.moveTo(pos.x, pos.y);
    }
    function draw(e) {
      if (!drawing) return;
      e.preventDefault();
      const pos = getPos(e);
      ctx.lineTo(pos.x, pos.y); ctx.stroke();
    }
    function endDraw() {
      if (!drawing) return;
      drawing = false;
      ttdInput.value = canvas.toDataURL('image/png');
    }
    canvas.addEventListener('mousedown', startDraw);
    canvas.addEventListener('mousemove', draw);
    window.addEventListener('mouseup', endDraw);
    canvas.addEventListener('touchstart', startDraw, { passive: false });
    canvas.addEventListener('touchmove', draw, { passive: false });
    canvas.addEventListener('touchend', endDraw);

    clearSignatureBtn.addEventListener('click', () => {
      const rect = canvas.getBoundingClientRect();
      ctx.clearRect(0, 0, rect.width, rect.height);
      hasSignature = false;
      ttdInput.value = '';
    });

    // ── Submit ──
    const form = document.getElementById('ttdDosenForm');
    const submitBtn = document.getElementById('submitBtn');
    const submitBtnText = document.getElementById('submitBtnText');
    const submitSpinner = document.getElementById('submitSpinner');

    form.addEventListener('submit', (e) => {
      if (!hasSignature) {
        e.preventDefault();
        signatureError.classList.remove('hidden');
        canvas.scrollIntoView({ behavior: 'smooth', block: 'center' });
        return;
      }
      submitBtn.disabled = true;
      submitBtnText.textContent = 'Menyimpan...';
      submitSpinner.classList.remove('hidden');
    });
  </script>

</body>
</html>
