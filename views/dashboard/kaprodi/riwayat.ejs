<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard Kaprodi - PPSU</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    .status-badge {
      display: inline-flex; align-items: center; gap: 0.3rem;
      padding: 0.3rem 0.75rem; border-radius: 9999px;
      font-size: 0.72rem; font-weight: 600; letter-spacing: 0.01em;
      white-space: nowrap;
    }
    .status-terjadwal  { background: #e0e7ff; color: #3730a3; }
    .status-disetujui  { background: #d1fae5; color: #065f46; }
    .status-ditolak    { background: #fee2e2; color: #991b1b; }

    .card-hover { transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease; }
    .card-hover:hover { transform: translateY(-2px); box-shadow: 0 10px 32px rgba(15, 23, 42, 0.07); border-color: #dbe4f0; }
    .meta-chip svg { color: #1e40af; }

    .tab-btn { transition: all .15s ease; }
    .tab-btn.active { background: #2563eb; color: #fff; }
    .tab-btn.active .tab-count { background: rgba(255,255,255,0.25); color: #fff; }

    .row-hover { transition: background-color .15s ease; }
    .row-hover:hover { background-color: #f8fafc; }

    .modal-overlay {
      position: fixed; inset: 0; background: rgba(15, 23, 42, 0.45);
      display: none; align-items: center; justify-content: center;
      padding: 1rem; z-index: 50;
    }
    .modal-overlay.active { display: flex; }
    @keyframes modalIn { from { opacity: 0; transform: translateY(8px) scale(.98); } to { opacity: 1; transform: translateY(0) scale(1); } }
    .modal-box { animation: modalIn .18s ease both; }

    ::-webkit-scrollbar { height: 8px; width: 8px; }
    ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 9999px; }
  </style>
</head>
<body class="bg-gray-100">

  <%- include('../../partials/sidebar_kaprodi', { user: locals.user, currentPath: locals.currentPath }) %>

  <div class="min-h-screen">
    <!-- TOP BAR -->
    <div class="bg-white border-b border-gray-200 px-6 py-4 flex items-center justify-between" style="padding-left: 64px;">
      <div class="flex items-center gap-3 pl-8">
        <img src="/images/paramadinalogo.svg" alt="PPSU" class="h-7 object-contain">
        <div class="w-px h-10 bg-gray-200"></div>
        <div class="flex flex-col leading-tight">
          <span class="text-sm font-bold text-gray-800">Dashboard Kaprodi</span>
          <span class="text-[10px] font-semibold text-blue-600 uppercase tracking-wider">
            Persetujuan Sidang &amp; Seminar Proposal
          </span>
        </div>
      </div>
    </div>

    <div class="px-6 py-8" style="padding-left: 64px;">
      <div class="max-w-[1700px] mx-auto">

        <!-- Alert -->
        <% if (locals.success_msg && success_msg.length > 0) { %>
          <div class="bg-green-50 border border-green-200 rounded-lg px-4 py-3 mb-4 text-green-700 text-sm flex items-center gap-2">
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <%= success_msg %>
          </div>
        <% } %>
        <% if (locals.error_msg && error_msg.length > 0) { %>
          <div class="bg-red-50 border border-red-200 rounded-lg px-4 py-3 mb-4 text-red-600 text-sm">
            <%= error_msg %>
          </div>
        <% } %>

        <% if (activeTab === 'menunggu') { %>

          <!-- ================= TAB: MENUNGGU PERSETUJUAN (gaya card) ================= -->
          <% if (daftarMenunggu.length === 0) { %>
            <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-14 flex flex-col items-center justify-center text-center">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-gray-300 mb-3">
                <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <p class="text-sm font-semibold text-gray-500">Tidak ada pengajuan yang menunggu persetujuan Anda</p>
              <p class="text-xs text-gray-400 mt-1">Pengajuan akan muncul di sini setelah ditandatangani Dosen Pembimbing dan dijadwalkan Admin PPSU.</p>
            </div>
          <% } else { %>
            <div class="space-y-4">
              <% daftarMenunggu.forEach(p => { %>
                <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden shadow-sm card-hover">
                  <div class="p-6">
                    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
                      <div class="flex-1">
                        <div class="flex flex-wrap items-center gap-3 mb-1">
                          <h3 class="text-base font-bold text-gray-800"><%= p.judul_karya_akhir %></h3>
                          <span class="status-badge status-terjadwal">
                            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                            Menunggu TTD Kaprodi
                          </span>
                        </div>
                        <p class="text-sm font-semibold text-blue-700 mb-3"><%= p.nama %></p>

                        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-4 gap-y-2.5">
                          <div class="meta-chip flex items-center gap-2 text-sm">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><rect x="2" y="5" width="20" height="14" rx="2"></rect><line x1="2" y1="10" x2="22" y2="10"></line></svg>
                            <span class="text-gray-400">NIM</span><span class="font-semibold text-gray-700"><%= p.nim %></span>
                          </div>
                          <div class="meta-chip flex items-center gap-2 text-sm">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
                            <span class="text-gray-400">Prodi</span><span class="font-semibold text-gray-700"><%= p.program_studi %></span>
                          </div>
                          <div class="meta-chip flex items-center gap-2 text-sm">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                            <span class="text-gray-400">Pembimbing</span><span class="font-semibold text-gray-700"><%= p.dosenPembimbing %></span>
                          </div>
                          <div class="meta-chip flex items-center gap-2 text-sm">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
                            <span class="text-gray-400">Jenis</span><span class="font-semibold text-gray-700"><%= (p.jenis_karya || 'Seminar Proposal') %></span>
                          </div>
                        </div>

                        <% if (p.jadwal) { %>
                          <div class="flex items-center gap-2 mt-3.5 text-xs text-gray-500 bg-gray-50 border border-gray-100 rounded-lg px-3 py-2 w-fit">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-700 shrink-0"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                            Dijadwalkan Admin PPSU: <span class="font-semibold text-gray-700"><%= p.jadwal && p.jadwal.tanggal ? new Date(p.jadwal.tanggal).toLocaleDateString('id-ID', {day:'numeric', month:'long', year:'numeric'}) : '-' %>, <%= p.jadwal && p.jadwal.jamMulai %>–<%= p.jadwal && p.jadwal.jamSelesai %> WIB</span>
                          </div>
                        <% } %>
                      </div>

                      <div class="flex flex-col gap-2 shrink-0 w-full md:w-auto">
                        <a href="/dashboard/kaprodi/persetujuan/<%= p._id %>/detail"
                           class="px-4 py-2 bg-blue-600 hover:bg-blue-700 rounded-lg text-sm font-semibold text-white transition flex items-center justify-center gap-1.5 shadow-md shadow-blue-200">
                          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                          Lihat &amp; Setujui
                        </a>
                      </div>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>

        <% } else { %>

          <!-- ================= TAB: RIWAYAT (gaya Data Management) ================= -->

          <!-- Ringkasan Statistik -->
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-6">
            <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-4 flex items-center gap-3">
              <span class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0" style="background:#e8effc; color:#1e40af;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
              </span>
              <div><p id="statTotal" class="text-lg font-bold text-gray-800">0</p><p class="text-[11px] font-medium text-gray-400">Total Riwayat</p></div>
            </div>
            <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-4 flex items-center gap-3">
              <span class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0" style="background:#d1fae5; color:#065f46;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
              </span>
              <div><p id="statDisetujui" class="text-lg font-bold text-gray-800">0</p><p class="text-[11px] font-medium text-gray-400">Disetujui</p></div>
            </div>
            <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-4 flex items-center gap-3">
              <span class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0" style="background:#fee2e2; color:#991b1b;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>
              </span>
              <div><p id="statDitolak" class="text-lg font-bold text-gray-800">0</p><p class="text-[11px] font-medium text-gray-400">Ditolak</p></div>
            </div>
          </div>

          <!-- Filter / Pencarian -->
          <div class="bg-white rounded-2xl border border-gray-200 p-4 mb-5 shadow-sm">
            <div class="flex flex-col lg:flex-row gap-3 items-center justify-between">
              <div class="flex flex-col sm:flex-row items-center gap-3 w-full lg:w-auto flex-1">
                <div class="relative w-full sm:w-72">
                  <input type="text" id="searchInput" placeholder="Cari nama, judul, atau NIM..."
                         class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                  <svg class="absolute left-3 top-2.5 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                  </svg>
                </div>
                <select id="filterStatus" class="w-full sm:w-auto px-3 py-2 border border-gray-300 rounded-lg text-sm text-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500">
                  <option value="">Semua Status</option>
                  <option value="disetujui">Disetujui</option>
                  <option value="ditolak">Ditolak</option>
                </select>
                <select id="filterProdi" class="w-full sm:w-auto px-3 py-2 border border-gray-300 rounded-lg text-sm text-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500">
                 <option value="">Semua Prodi</option>
                <option value="Teknik Informatika">Teknik Informatika</option>
                <option value="Desain Komunikasi Visual">Desain Komunikasi Visual</option>
                <option value="Desain Produk">Desain Produk</option>
                </select>
              </div>
              <div class="flex items-center gap-2 pr-2">
                <button type="button" id="btnExportCsv"
                   class="flex items-center gap-2 bg-white hover:bg-gray-50 border border-gray-200 rounded-full px-4 py-2 transition-colors shadow-sm">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-600">
                    <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line>
                  </svg>
                  <span class="text-xs font-semibold text-gray-700">Ekspor CSV</span>
                </button>
                <span class="text-xs text-gray-400 whitespace-nowrap" id="resultCountLabel">Menampilkan 0 data</span>
              </div>
            </div>
          </div>

          <!-- Tabel Riwayat -->
          <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
            <div class="overflow-x-auto">
              <table class="w-full text-sm" id="dataTable">
                <thead>
                  <tr class="bg-gray-50 border-b border-gray-200 text-left">
                    <th class="px-4 py-3 font-semibold text-gray-500 text-xs uppercase tracking-wide w-10">No</th>
                    <th class="px-4 py-3 font-semibold text-gray-500 text-xs uppercase tracking-wide cursor-pointer select-none" data-sort="judul">Judul & Mahasiswa</th>
                    <th class="px-4 py-3 font-semibold text-gray-500 text-xs uppercase tracking-wide cursor-pointer select-none" data-sort="prodi">Prodi</th>
                    <th class="px-4 py-3 font-semibold text-gray-500 text-xs uppercase tracking-wide">Pembimbing</th>
                    <th class="px-4 py-3 font-semibold text-gray-500 text-xs uppercase tracking-wide">Jenis</th>
                    <th class="px-4 py-3 font-semibold text-gray-500 text-xs uppercase tracking-wide cursor-pointer select-none" data-sort="keputusan">Tgl. Keputusan</th>
                    <th class="px-4 py-3 font-semibold text-gray-500 text-xs uppercase tracking-wide">Status</th>
                    <th class="px-4 py-3 font-semibold text-gray-500 text-xs uppercase tracking-wide text-center">Aksi</th>
                  </tr>
                </thead>
                <tbody id="tableBody" class="divide-y divide-gray-100">
                  <!-- Rows di-render via JS -->
                </tbody>
              </table>
            </div>

            <div id="emptyState" class="hidden flex-col items-center justify-center py-14 text-center">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-gray-300 mb-3"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
              <p class="text-sm font-semibold text-gray-500">Tidak ada data yang cocok</p>
              <p class="text-xs text-gray-400 mt-1">Coba ubah kata kunci atau filter pencarian</p>
            </div>

            <!-- Pagination -->
            <div class="flex flex-col sm:flex-row items-center justify-between gap-3 px-4 py-3.5 border-t border-gray-100">
              <span class="text-xs text-gray-400" id="paginationLabel">Halaman 1 dari 1</span>
              <div class="flex items-center gap-1" id="paginationControls"></div>
            </div>
          </div>

          <!-- ══════════ MODAL: DETAIL RIWAYAT ══════════ -->
          <div class="modal-overlay" id="modalDetail">
            <div class="modal-box bg-white rounded-2xl shadow-xl w-full max-w-2xl max-h-[90vh] overflow-y-auto">
              <div class="px-6 py-4 flex items-center justify-between sticky top-0 z-10" style="background: linear-gradient(135deg, #1e40af 0%, #2563eb 100%);">
                <div>
                  <span class="text-white font-bold text-sm tracking-wide">DETAIL RIWAYAT PERSETUJUAN</span>
                  <p class="text-blue-200 text-xs mt-0.5" id="modalDetailSubtitle">-</p>
                </div>
                <button type="button" class="modal-close text-white/80 hover:text-white" data-modal="modalDetail">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                </button>
              </div>
              <div class="px-6 py-6" id="modalDetailBody">
                <!-- Diisi via JS -->
              </div>
            </div>
          </div>

          <script>
            // Data riwayat dikirim dari server (route /kaprodi)
            const riwayatDataRaw = <%- JSON.stringify(riwayatList) %>;

            const riwayatData = riwayatDataRaw.map(p => ({
              id: p._id,
              judul: p.judul_karya_akhir,
              mahasiswa: p.nama || (p.pemohonId ? p.pemohonId.name : '-'),
              nim: p.nim || (p.pemohonId && p.pemohonId.profile ? p.pemohonId.profile.nim : '-'),
              prodi: p.program_studi || (p.pemohonId && p.pemohonId.profile ? p.pemohonId.profile.programStudi : '-'),
              pembimbing: p.dosenPembimbing || (p.dosenPembimbingId ? p.dosenPembimbingId.name : '-'),
              jenis: (p.jenis_karya || 'Seminar Proposal') || p.jenis_karya || '-',
              diajukan: p.tanggalDiajukan,
              status: p.statusKaprodi,                 // 'disetujui' | 'ditolak'
              tanggalKeputusan: p.tanggalKeputusanFormatted,
              signedAtKaprodi: p.signedAtKaprodi,       // ISO string, untuk sorting
              jadwal: p.jadwal,
              alasanTolak: p.alasanTolakKaprodi
            }));

            const statusMeta = {
              disetujui: { label: 'Disetujui', cls: 'status-disetujui', icon: '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>' },
              ditolak:   { label: 'Ditolak',   cls: 'status-ditolak',   icon: '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>' }
            };

            let currentSort = { key: 'signedAtKaprodi', dir: 'desc' };
            let currentPage = 1;
            const pageSize = 8;

            function populateProdiFilter() {
              const prodiSet = [...new Set(riwayatData.map(d => d.prodi).filter(Boolean))];
              const sel = document.getElementById('filterProdi');
              prodiSet.forEach(p => {
                const opt = document.createElement('option');
                opt.value = p; opt.textContent = p;
                sel.appendChild(opt);
              });
            }

            function getFiltered() {
              const q = document.getElementById('searchInput')?.value.trim().toLowerCase() || '';
              const st = document.getElementById('filterStatus')?.value || '';
              const pr = document.getElementById('filterProdi')?.value || '';
              const jn = document.getElementById('filterJenis')?.value || '';

              let rows = riwayatData.filter(d => {
                const matchQ = !q || (d.judul || '').toLowerCase().includes(q) || (d.mahasiswa || '').toLowerCase().includes(q) || (d.nim || '').toLowerCase().includes(q);
                const matchSt = !st || d.status === st;
                const matchPr = !pr || d.prodi === pr;
                const matchJn = !jn || d.jenis === jn;
                return matchQ && matchSt && matchPr && matchJn;
              });

              rows.sort((a, b) => {
                let va = a[currentSort.key] || '', vb = b[currentSort.key] || '';
                if (currentSort.key === 'signedAtKaprodi') { va = new Date(va || 0); vb = new Date(vb || 0); }
                if (va < vb) return currentSort.dir === 'asc' ? -1 : 1;
                if (va > vb) return currentSort.dir === 'asc' ? 1 : -1;
                return 0;
              });

              return rows;
            }

            function renderStats() {
              const counts = { disetujui: 0, ditolak: 0 };
              riwayatData.forEach(d => { if (counts[d.status] !== undefined) counts[d.status]++; });
              document.getElementById('statTotal').textContent = riwayatData.length;
              document.getElementById('statDisetujui').textContent = counts.disetujui;
              document.getElementById('statDitolak').textContent = counts.ditolak;
            }

            function renderTable() {
              const filtered = getFiltered();
              const tbody = document.getElementById('tableBody');
              const emptyState = document.getElementById('emptyState');
              const totalPages = Math.max(1, Math.ceil(filtered.length / pageSize));
              if (currentPage > totalPages) currentPage = totalPages;
              const start = (currentPage - 1) * pageSize;
              const pageRows = filtered.slice(start, start + pageSize);

              document.getElementById('resultCountLabel').textContent = `Menampilkan ${filtered.length} data`;
              document.getElementById('paginationLabel').textContent = `Halaman ${currentPage} dari ${totalPages}`;

              if (pageRows.length === 0) {
                tbody.innerHTML = '';
                emptyState.classList.remove('hidden');
                emptyState.classList.add('flex');
              } else {
                emptyState.classList.add('hidden');
                emptyState.classList.remove('flex');

                tbody.innerHTML = pageRows.map((d, i) => {
                  const meta = statusMeta[d.status] || { label: d.status, cls: '', icon: '' };
                  return `
                    <tr class="row-hover" data-id="${d.id}">
                      <td class="px-4 py-3.5 text-gray-400 text-xs align-top">${start + i + 1}</td>
                      <td class="px-4 py-3.5 align-top">
                        <p class="font-semibold text-gray-800 text-sm leading-snug">${d.judul}</p>
                        <p class="text-xs text-blue-700 font-medium mt-0.5">${d.mahasiswa} <span class="text-gray-400 font-normal">· ${d.nim}</span></p>
                      </td>
                      <td class="px-4 py-3.5 align-top text-xs text-gray-600">${d.prodi}</td>
                      <td class="px-4 py-3.5 align-top text-xs text-gray-600">${d.pembimbing || '-'}</td>
                      <td class="px-4 py-3.5 align-top text-xs text-gray-600">${d.jenis}</td>
                      <td class="px-4 py-3.5 align-top text-xs text-gray-600">${d.tanggalKeputusan}</td>
                      <td class="px-4 py-3.5 align-top">
                        <span class="status-badge ${meta.cls}">${meta.icon} ${meta.label}</span>
                      </td>
                      <td class="px-4 py-3.5 align-top text-center">
                        <button type="button" class="btn-detail text-xs font-semibold text-blue-600 hover:text-blue-700 hover:underline" data-id="${d.id}">
                          Lihat Detail
                        </button>
                      </td>
                    </tr>
                  `;
                }).join('');
              }

              renderPagination(totalPages);
              attachRowEvents();
            }

            function renderPagination(totalPages) {
              const container = document.getElementById('paginationControls');
              container.innerHTML = '';
              const mkBtn = (label, page, disabled, active) => {
                const btn = document.createElement('button');
                btn.type = 'button';
                btn.textContent = label;
                btn.className = `px-3 py-1.5 rounded-lg text-xs font-semibold transition ${
                  active ? 'bg-blue-600 text-white' : disabled ? 'text-gray-300 cursor-not-allowed' : 'text-gray-600 hover:bg-gray-100'
                }`;
                if (!disabled) btn.addEventListener('click', () => { currentPage = page; renderTable(); });
                return btn;
              };
              container.appendChild(mkBtn('‹ Prev', currentPage - 1, currentPage === 1, false));
              for (let p = 1; p <= totalPages; p++) {
                container.appendChild(mkBtn(String(p), p, false, p === currentPage));
              }
              container.appendChild(mkBtn('Next ›', currentPage + 1, currentPage === totalPages, false));
            }

            function attachRowEvents() {
              document.querySelectorAll('.btn-detail').forEach(btn => {
                btn.addEventListener('click', () => openDetail(btn.dataset.id));
              });
            }

            function openDetail(id) {
              const d = riwayatData.find(x => x.id === id);
              if (!d) return;
              const meta = statusMeta[d.status] || { label: d.status, cls: '', icon: '' };
              document.getElementById('modalDetailSubtitle').textContent = d.judul;

              let extra = '';
              if (d.status === 'disetujui' && d.jadwal) {
                const pengujiHtml = (d.jadwal.penguji || []).map((p, i) => `<p class="text-sm text-gray-800 font-medium">${i + 1}. ${p.nama} <span class="text-gray-400 font-normal">(${p.peran})</span></p>`).join('') || '<p class="text-sm text-gray-400">Belum ada penguji</p>';
                extra = `
                  <div class="rounded-xl border border-gray-200 overflow-hidden mt-4">
                    <div class="px-4 py-2.5 flex items-center gap-2" style="background: linear-gradient(135deg, #1e40af 0%, #2563eb 100%);">
                      <span class="text-xs font-bold text-white tracking-wide">INFORMASI SIDANG</span>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-3 p-4" style="background:#f8fafc;">
                      <div class="bg-white rounded-lg p-3 border border-gray-200">
                        <p class="text-[11px] font-bold uppercase tracking-wide text-gray-500 mb-1.5">Jadwal</p>
                        <p class="text-sm text-gray-800">${d.jadwal.tanggal || '-'}</p>
                        <p class="text-sm text-gray-800">${d.jadwal.jamMulai || ''}${d.jadwal.jamSelesai ? '–' + d.jadwal.jamSelesai : ''} WIB</p>
                      </div>
                      <div class="bg-white rounded-lg p-3 border border-gray-200">
                        <p class="text-[11px] font-bold uppercase tracking-wide text-gray-500 mb-1.5">Tim Penguji</p>
                        ${pengujiHtml}
                      </div>
                      <div class="bg-white rounded-lg p-3 border border-gray-200">
                        <p class="text-[11px] font-bold uppercase tracking-wide text-gray-500 mb-1.5">Teknik Sidang</p>
                        <p class="text-sm text-gray-800">${d.jadwal.teknik === 'online' ? 'Daring (Online)' : 'Tatap Muka (Offline)'}</p>
                        <p class="text-xs text-gray-500 mt-1 truncate">${d.jadwal.linkMeeting || d.jadwal.ruang || '-'}</p>
                      </div>
                    </div>
                  </div>
                `;
              } else if (d.status === 'ditolak') {
                extra = `
                  <div class="flex items-start gap-3 rounded-xl border border-red-200 bg-red-50 p-3.5 mt-4">
                    <div>
                      <p class="text-sm text-red-800 font-semibold">Alasan Penolakan</p>
                      <p class="text-sm text-red-700 mt-0.5">${d.alasanTolak || '-'}</p>
                    </div>
                  </div>
                `;
              }

              document.getElementById('modalDetailBody').innerHTML = `
                <div class="flex flex-wrap items-center gap-3 mb-4">
                  <span class="status-badge ${meta.cls}">${meta.icon} ${meta.label}</span>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-3 text-sm">
                  <p><span class="text-gray-400">Mahasiswa:</span> <span class="font-semibold text-gray-800">${d.mahasiswa}</span></p>
                  <p><span class="text-gray-400">NIM:</span> <span class="font-semibold text-gray-800">${d.nim}</span></p>
                  <p><span class="text-gray-400">Prodi:</span> <span class="font-semibold text-gray-800">${d.prodi}</span></p>
                  <p><span class="text-gray-400">Pembimbing:</span> <span class="font-semibold text-gray-800">${d.pembimbing || '-'}</span></p>
                  <p><span class="text-gray-400">Jenis Sidang:</span> <span class="font-semibold text-gray-800">${d.jenis}</span></p>
                  <p><span class="text-gray-400">Tgl. Keputusan:</span> <span class="font-semibold text-gray-800">${d.tanggalKeputusan}</span></p>
                </div>
                ${extra}
              `;
              openModal('modalDetail');
            }

            function openModal(id) { document.getElementById(id).classList.add('active'); }
            function closeModal(id) { document.getElementById(id).classList.remove('active'); }
            document.querySelectorAll('.modal-close').forEach(btn => btn.addEventListener('click', () => closeModal(btn.dataset.modal)));
            document.querySelectorAll('.modal-overlay').forEach(overlay => overlay.addEventListener('click', e => { if (e.target === overlay) closeModal(overlay.id); }));

            // Sorting header
            document.querySelectorAll('[data-sort]').forEach(th => {
              th.addEventListener('click', () => {
                const map = { judul: 'judul', prodi: 'prodi', keputusan: 'signedAtKaprodi' };
                const key = map[th.dataset.sort] || th.dataset.sort;
                if (currentSort.key === key) currentSort.dir = currentSort.dir === 'asc' ? 'desc' : 'asc';
                else currentSort = { key, dir: 'asc' };
                renderTable();
              });
            });

            // Event Listeners Filter
            ['searchInput', 'filterStatus', 'filterProdi', 'filterJenis'].forEach(id => {
              const el = document.getElementById(id);
              if (el) {
                el.addEventListener(id === 'searchInput' ? 'input' : 'change', () => { currentPage = 1; renderTable(); });
              }
            });

            const btnReset = document.getElementById('btnResetFilter');
            if (btnReset) {
              btnReset.addEventListener('click', () => {
                const q = document.getElementById('searchInput'); if (q) q.value = '';
                const st = document.getElementById('filterStatus'); if (st) st.value = '';
                const pr = document.getElementById('filterProdi'); if (pr) pr.value = '';
                const jn = document.getElementById('filterJenis'); if (jn) jn.value = '';
                currentPage = 1; renderTable();
              });
            }

            // Ekspor CSV dari data yang sedang ter-filter
            document.getElementById('btnExportCsv')?.addEventListener('click', () => {
              const rows = getFiltered();
              const header = ['No', 'Judul', 'Mahasiswa', 'NIM', 'Prodi', 'Pembimbing', 'Jenis', 'Tgl. Keputusan', 'Status'];
              const csvRows = rows.map((d, i) => [
                i + 1, d.judul, d.mahasiswa, d.nim, d.prodi, d.pembimbing || '-', d.jenis,
                d.tanggalKeputusan, (statusMeta[d.status] || {}).label || d.status
              ]);
              const csvContent = [header, ...csvRows]
                .map(r => r.map(v => `"${String(v).replace(/"/g, '""')}"`).join(','))
                .join('\n');
              const blob = new Blob(['\ufeff' + csvContent], { type: 'text/csv;charset=utf-8;' });
              const url = URL.createObjectURL(blob);
              const a = document.createElement('a');
              a.href = url;
              a.download = `riwayat-persetujuan-kaprodi-${new Date().toISOString().slice(0, 10)}.csv`;
              document.body.appendChild(a);
              a.click();
              document.body.removeChild(a);
              URL.revokeObjectURL(url);
            });

            // Init
            populateProdiFilter();
            renderStats();
            renderTable();
          </script>

        <% } %>

      </div>
    </div>
  </div>

</body>
</html>
