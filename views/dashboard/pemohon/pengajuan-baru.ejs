<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Formulir Pendaftaran Sidang - PPSU</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @keyframes spin { to { transform: rotate(360deg); } }
    .animate-spin { animation: spin 1s linear infinite; }
    #signatureCanvas {
      touch-action: none;
      cursor: crosshair;
    }
    .step-content { display: none; }
    .step-content.active { display: block; }
  </style>
</head>
<body class="bg-gray-100">

  <%- include('../../partials/sidebar', { user: locals.user, currentPath: locals.currentPath }) %>

  <div class="min-h-screen">
    <!-- ─── TOP BAR ─── -->
    <div class="bg-white border-b border-gray-200 px-6 py-4 flex items-center justify-between" style="padding-left: 64px;">
      <div class="flex items-center gap-3 pl-8">
        <img src="/images/paramadinalogo.svg" alt="PPSU" class="h-7 object-contain">
        <div class="w-px h-10 bg-gray-200"></div>
        <div class="flex flex-col leading-tight">
          <span class="text-sm font-bold text-gray-800">Entry Data</span>
          <span class="text-[10px] font-semibold text-blue-600 uppercase tracking-wider">
            Formulir Pendaftaran Sidang
          </span>
        </div>
      </div>

      <!-- Step indicator (3 steps) -->
      <div class="flex items-center gap-0">
        <div class="flex items-center">
          <div class="flex items-center gap-2 px-3">
            <div id="ind1-circle" class="w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold shrink-0 bg-blue-600 text-white">1</div>
            <span id="ind1-text" class="text-xs font-medium text-blue-600">Data Pendaftaran</span>
          </div>
          <div id="ind1-line" class="w-8 h-px bg-gray-200"></div>
        </div>
        <div class="flex items-center">
          <div class="flex items-center gap-2 px-3">
            <div id="ind2-circle" class="w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold shrink-0 bg-gray-100 text-gray-400">2</div>
            <span id="ind2-text" class="text-xs font-medium text-gray-400">Konfirmasi</span>
          </div>
          <div id="ind2-line" class="w-8 h-px bg-gray-200"></div>
        </div>
        <div class="flex items-center">
          <div class="flex items-center gap-2 px-3">
            <div id="ind3-circle" class="w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold shrink-0 bg-gray-100 text-gray-400">3</div>
            <span id="ind3-text" class="text-xs font-medium text-gray-400">Detail &amp; Kirim</span>
          </div>
        </div>
      </div>
    </div>

    <div class="px-6 py-8" style="padding-left: 64px;">
      <!-- Alerts -->
      <% if (locals.success_msg && success_msg.length > 0) { %>
        <p class="text-green-600 text-sm bg-green-50 border border-green-200 rounded-lg px-4 py-3 mb-4">
          <%= success_msg %>
        </p>
      <% } %>
      <% if (locals.error_msg && error_msg.length > 0) { %>
        <p class="text-red-500 text-sm bg-red-50 border border-red-200 rounded-lg px-4 py-3 mb-4">
          <%= error_msg %>
        </p>
      <% } %>

      <form id="pengajuanForm" class="bg-white rounded-xl border border-gray-200 overflow-hidden shadow-sm">
        
        <!-- =================== STEP 1: DATA PENDAFTARAN =================== -->
        <div id="step1" class="step-content active">
          <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between"
            style="background: linear-gradient(135deg, #1e40af 0%, #2563eb 100%);">
            <div>
              <span class="text-white font-bold text-sm tracking-wide">FORMULIR PENDAFTARAN SIDANG</span>
              <p class="text-blue-200 text-xs mt-0.5">Fakultas Ilmu Rekayasa &middot; Universitas Paramadina</p>
            </div>
            <span class="text-xs bg-white/20 text-white px-3 py-1 rounded-full font-medium whitespace-nowrap">
              Sidang Seminar Proposal / Kolokium
            </span>
          </div>

          <div class="px-8 py-6 space-y-5">
            <p class="text-sm text-gray-600 italic -mb-1">Form Pendaftaran: (diisi oleh mahasiswa)</p>
            <p class="text-sm text-gray-700 mb-1">Yang bertanda tangan di bawah ini:</p>

            <div class="flex items-start gap-4">
              <label for="nama" class="w-64 text-sm text-gray-700 shrink-0 font-medium pt-2">Nama <span class="text-red-500">*</span></label>
              <span class="text-gray-400 shrink-0 pt-2">:</span>
              <div class="flex-1"><input type="text" id="nama" name="nama" required value="<%= locals.user ? user.name : '' %>" class="w-full border border-gray-300 rounded px-3 py-2 text-sm text-gray-600 focus:outline-none focus:ring-1 focus:ring-blue-400 bg-white"></div>
            </div>

            <div class="flex items-start gap-4">
              <label for="nim" class="w-64 text-sm text-gray-700 shrink-0 font-medium pt-2">NIM <span class="text-red-500">*</span></label>
              <span class="text-gray-400 shrink-0 pt-2">:</span>
              <div class="flex-1"><input type="text" id="nim" name="nim" required inputmode="numeric" class="w-full border border-gray-300 rounded px-3 py-2 text-sm text-gray-600 focus:outline-none focus:ring-1 focus:ring-blue-400 bg-white"></div>
            </div>

            <div class="flex items-start gap-4">
              <label for="program_studi" class="w-64 text-sm text-gray-700 shrink-0 font-medium pt-2">Program Studi <span class="text-red-500">*</span></label>
              <span class="text-gray-400 shrink-0 pt-2">:</span>
              <div class="flex-1">
                <select id="program_studi" name="program_studi" required class="w-full border border-gray-300 rounded px-3 py-2 text-sm text-gray-600 focus:outline-none focus:ring-1 focus:ring-blue-400 bg-white">
                  <option value="" disabled selected>Pilih Program Studi</option>
                  <option value="Teknik Informatika">Teknik Informatika</option>
                  <option value="Desain Produk">Desain Produk</option>
                  <option value="Desain Komunikasi Visual">Desain Komunikasi Visual</option>
                </select>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <label class="w-64 text-sm text-gray-700 shrink-0 font-medium pt-2">Jenis Sidang <span class="text-red-500">*</span></label>
              <span class="text-gray-400 shrink-0 pt-2">:</span>
              <div class="flex-1 flex flex-col sm:flex-row gap-3 pt-2">
                <label class="flex items-center gap-2 text-sm text-gray-700"><input type="radio" name="jenis_sidang" id="jenis_seminar_proposal" value="seminar_proposal" required class="text-blue-600 focus:ring-blue-500"> Sidang Seminar Proposal</label>
                <label class="flex items-center gap-2 text-sm text-gray-700"><input type="radio" name="jenis_sidang" id="jenis_kolokium" value="kolokium" required class="text-blue-600 focus:ring-blue-500"> Sidang Kolokium</label>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <label for="alamat" class="w-64 text-sm text-gray-700 shrink-0 font-medium pt-2">Alamat <span class="text-red-500">*</span></label>
              <span class="text-gray-400 shrink-0 pt-2">:</span>
              <div class="flex-1"><textarea id="alamat" name="alamat" rows="2" required class="w-full border border-gray-300 rounded px-3 py-2 text-sm text-gray-600 focus:outline-none focus:ring-1 focus:ring-blue-400 bg-white resize-none"></textarea></div>
            </div>

            <div class="flex items-start gap-4">
              <label for="no_hp" class="w-64 text-sm text-gray-700 shrink-0 font-medium pt-2">No. HP <span class="text-red-500">*</span></label>
              <span class="text-gray-400 shrink-0 pt-2">:</span>
              <div class="flex-1">
                <input type="tel" id="no_hp" name="no_hp" required inputmode="numeric" pattern="[0-9]*" maxlength="15" placeholder="Contoh: 081234567890" class="w-full border border-gray-300 rounded px-3 py-2 text-sm text-gray-600 focus:outline-none focus:ring-1 focus:ring-blue-400 bg-white">
                <p id="noHpError" class="hidden text-red-500 text-xs mt-1">No. HP hanya boleh berisi angka.</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <label for="email" class="w-64 text-sm text-gray-700 shrink-0 font-medium pt-2">Email <span class="text-red-500">*</span></label>
              <span class="text-gray-400 shrink-0 pt-2">:</span>
              <div class="flex-1"><input type="email" id="email" name="email" required class="w-full border border-gray-300 rounded px-3 py-2 text-sm text-gray-600 focus:outline-none focus:ring-1 focus:ring-blue-400 bg-white"></div>
            </div>

            <div class="flex items-start gap-4">
              <label for="judul_karya_akhir" class="w-64 text-sm text-gray-700 shrink-0 font-medium pt-2">Judul Karya Akhir <span class="text-red-500">*</span></label>
              <span class="text-gray-400 shrink-0 pt-2">:</span>
              <div class="flex-1"><textarea id="judul_karya_akhir" name="judul_karya_akhir" rows="3" required class="w-full border border-gray-300 rounded px-3 py-2 text-sm text-gray-600 focus:outline-none focus:ring-1 focus:ring-blue-400 bg-white resize-none"></textarea></div>
            </div>

            <div class="border-t border-gray-100 pt-5 space-y-5">
              <!-- Upload Draft Karya Akhir -->
              <div class="flex items-start gap-4">
                <label for="file_draft_karya_akhir" class="w-64 text-sm text-gray-700 shrink-0 font-medium pt-2">
                  Draft Softfile Karya Akhir <span class="text-red-500">*</span>
                </label>
                <span class="text-gray-400 shrink-0 pt-2">:</span>
                <div class="flex-1">
                  <input type="file" id="file_draft_karya_akhir" name="file_draft_karya_akhir" accept="application/pdf" required
                    class="w-full text-sm text-gray-600 border border-gray-300 rounded px-3 py-2 file:mr-4 file:py-1 file:px-3 file:rounded file:border-0 file:text-xs file:font-medium file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 transition bg-white">
                  <p class="text-xs text-gray-400 mt-1">Draft yang telah disetujui Dosen Pembimbing Karya Akhir. Format PDF, maks 10MB.</p>
                </div>
              </div>

              <!-- Tanda Tangan -->
              <div class="flex items-start gap-4">
                <label class="w-64 text-sm text-gray-700 shrink-0 font-medium pt-2">Tanda Tangan Pemohon (E-sign) <span class="text-red-500">*</span></label>
                <span class="text-gray-400 shrink-0 pt-2">:</span>
                <div class="flex-1">
                  <div class="border border-gray-300 rounded-lg overflow-hidden bg-white">
                    <canvas id="signatureCanvas" class="w-full block bg-white" height="50"></canvas>
                  </div>
                  <div class="flex items-center justify-between mt-2">
                    <p class="text-xs text-gray-400">Tanda tangan langsung di area di atas.</p>
                    <button type="button" id="clearSignatureBtn" class="shrink-0 ml-3 px-3 py-1.5 rounded text-xs font-medium border border-gray-300 text-gray-600 hover:bg-gray-50 transition">Hapus &amp; Ulangi</button>
                  </div>
                  <p id="signatureError" class="hidden text-red-500 text-xs mt-1">Tanda tangan wajib diisi.</p>
                  <input type="hidden" id="ttd_pemohon" name="ttd_pemohon">
                </div>
              </div>
            </div>

            <!-- Ketentuan Pengajuan -->
            <div class="rounded-lg overflow-hidden mt-2" style="border: 1px solid #dbe4f0;">
              <div class="flex items-center gap-2.5 px-4 py-2.5" style="background: linear-gradient(135deg, #1e3a6e 0%, #1e40af 100%);">
                <span class="text-white text-xs font-bold tracking-wide uppercase">Ketentuan Pengajuan</span>
              </div>
              <div class="bg-slate-50 px-4 py-3.5">
                <ul class="space-y-2.5">
                  <li class="flex items-start gap-2.5">
                    <span class="text-xs text-gray-700 leading-relaxed">Form ditandatangani langsung secara elektronik oleh pemohon (mahasiswa) pada area tanda tangan di atas.</span>
                  </li>
                  <li class="flex items-start gap-2.5">
                    <span class="text-xs text-gray-700 leading-relaxed">Melampirkan draft softfile Karya Akhir yang telah disetujui Dosen Pembimbing Karya Akhir.</span>
                  </li>
                  <li class="flex items-start gap-2.5">
                    <span class="text-xs text-gray-700 leading-relaxed">Form yang telah lengkap diisi dan ditandatangani beserta Draft softfile Karya Akhir diajukan melalui sistem ini.</span>
                  </li>
                </ul>
              </div>
            </div>

            <p id="clientErrorStep1" class="hidden text-red-500 text-xs bg-red-50 border border-red-200 rounded-lg px-3 py-2"></p>
          </div>

          <div class="flex justify-end gap-3 py-6 px-8 border-t border-gray-100">
            <button type="button" id="saveCloseBtn" class="px-6 py-2 rounded-lg bg-green-500 hover:bg-green-600 text-white text-sm font-semibold transition shadow-md shadow-green-200">
             Tutup
            </button>
            <button type="button" onclick="goToStep(2)" class="px-6 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold transition shadow-md shadow-blue-200">
              Next
            </button>
          </div>
        </div>

        <!-- =================== STEP 2: KONFIRMASI =================== -->
        <div id="step2" class="step-content">
          <div class="px-6 py-4 border-b border-gray-100" style="background: linear-gradient(135deg, #1e40af 0%, #2563eb 100%);">
            <span class="text-white font-bold text-sm tracking-wide">KONFIRMASI PENDAFTARAN</span>
            <p class="text-blue-200 text-xs mt-0.5">Informasi tahap persetujuan setelah pendaftaran dikirim</p>
          </div>
          <div class="px-8 py-6">
            <p class="text-sm font-semibold text-gray-700 mb-3">Form Persetujuan (Setelah Pendaftaran Dikirim)</p>
            <div class="border border-gray-200 rounded-lg bg-gray-50 px-6 py-5 opacity-70 pointer-events-none select-none">
              <p class="text-sm font-bold text-gray-500">Form Persetujuan: <span class="italic font-semibold">(diisi oleh Kaprodi)</span></p>
              <p class="text-xs text-gray-400 mt-3 leading-relaxed">
                Dengan ini Ketua Program Studi menyetujui mahasiswa mendapat tim penguji
                Seminar Proposal/Sidang Kolokium (*coret salah satu), yaitu:
              </p>
              <div class="mt-4 space-y-2 text-xs text-gray-400">
                <div class="flex gap-2"><span class="w-32 shrink-0">Ketua Penguji</span><span>:</span><span class="flex-1 border-b border-dotted border-gray-300"></span></div>
                <div class="flex gap-2"><span class="w-32 shrink-0">Anggota Penguji</span><span>:</span><span class="flex-1 border-b border-dotted border-gray-300"></span></div>
              </div>
              <p class="text-xs text-gray-400 mt-4 leading-relaxed">
                Demikian Ketua Program Studi menyetujui keputusan tersebut untuk dapat dilanjutkan
                sampai pada kegiatan sidang akhir dan diinformasikan ke mahasiswa serta pihak-pihak terkait.
              </p>
              <div class="mt-4 text-xs text-gray-400">
                <p>Jakarta, ………………………</p>
                <p class="mt-1">Menyetujui,</p>
                <p class="mt-6 italic">e-sign Kaprodi</p>
              </div>
            </div>
            <p class="text-xs text-gray-400 mt-2">
              Bagian ini akan diisi dan ditandatangani oleh Kaprodi setelah pendaftaran kamu dikirim — tidak perlu diisi sekarang.
            </p>
          </div>
          <div class="flex justify-end gap-3 py-6 px-8 border-t border-gray-100">
            <button type="button" onclick="goToStep(1)" class="px-6 py-2 rounded-lg border border-gray-300 text-gray-600 text-sm font-semibold hover:bg-gray-50 transition">Kembali</button>
            <button type="button" onclick="goToStep(3)" class="px-6 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold transition shadow-md shadow-blue-200">Lanjutkan</button>
          </div>
        </div>

        <!-- =================== STEP 3: DETAIL & KIRIM =================== -->
        <div id="step3" class="step-content">
          <div class="px-6 py-4 border-b border-gray-100" style="background: linear-gradient(135deg, #1e40af 0%, #2563eb 100%);">
            <span class="text-white font-bold text-sm tracking-wide">DETAIL PENDAFTARAN</span>
            <p class="text-blue-200 text-xs mt-0.5">Periksa kembali seluruh data sebelum dikirim</p>
          </div>
          <div class="px-8 py-6 space-y-6">
            <!-- Ringkasan Data -->
            <div>
              <div class="flex items-center justify-between mb-3">
                <p class="text-sm font-bold text-gray-800">Ringkasan Data Pendaftaran</p>
                <button type="button" onclick="goToStep(1)" class="text-xs font-semibold text-blue-600 hover:text-blue-700 border border-blue-200 hover:border-blue-300 hover:bg-blue-50 rounded-lg px-3 py-1.5 transition">Ubah Data</button>
              </div>
              <div id="ringkasanBox" class="rounded-xl overflow-hidden text-sm text-gray-700" style="border: 1px solid #dbe4f0; background: #f8fafc;">
                <!-- Diisi via JS -->
              </div>
            </div>

            <!-- Tanda Tangan -->
            <div class="border-t border-gray-100 pt-5">
              <p class="text-sm font-bold text-gray-800 mb-4">Tanda Tangan</p>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <p class="text-[11px] font-semibold uppercase tracking-wide mb-2" style="color: #7c8aa5;">Tanda Tangan Pemohon</p>
                  <div class="border rounded-lg bg-white p-3 h-28 flex items-center justify-center" style="border-color: #dbe4f0;">
                    <img id="ttdPreviewImg" src="" alt="Tanda tangan pemohon" class="h-20">
                  </div>
                </div>
                <div>
                  <p class="text-[11px] font-semibold uppercase tracking-wide mb-2" style="color: #7c8aa5;">Mengetahui, Dosen Pembimbing</p>
                  <div class="border border-dashed rounded-lg bg-gray-50 p-3 h-28 flex flex-col items-center justify-center gap-1.5" style="border-color: #cbd5e1;">
                    <span class="text-xs text-gray-400 text-center leading-relaxed">Menunggu tanda tangan<br>Dosen Pembimbing</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="flex justify-end gap-3 py-6 px-8 border-t border-gray-100">
            <button type="button" onclick="goToStep(2)" class="px-6 py-2 rounded-lg border border-gray-300 text-gray-600 text-sm font-semibold hover:bg-gray-50 transition">Kembali</button>
            <button type="submit" id="submitBtn" class="px-6 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold transition shadow-md shadow-blue-200">
              <span id="submitBtnText">Kirim Pengajuan</span>
            </button>
          </div>
        </div>

      </form>
    </div>
  </div>

  <script>
    const form = document.getElementById('pengajuanForm');
    const noHpInput = document.getElementById('no_hp');
    const noHpError = document.getElementById('noHpError');
    const prodiSelect = document.getElementById('program_studi');

    // No. HP: hanya izinkan angka
    noHpInput.addEventListener('input', () => {
      const filtered = noHpInput.value.replace(/\D/g, '').slice(0, 15);
      if (filtered !== noHpInput.value) {
        noHpInput.value = filtered;
        noHpError.classList.remove('hidden');
      } else {
        noHpError.classList.add('hidden');
      }
    });

    // Auto-pilih Jenis Sidang berdasarkan Program Studi
    prodiSelect.addEventListener('change', () => {
      if (prodiSelect.value === 'Teknik Informatika') {
        document.getElementById('jenis_seminar_proposal').checked = true;
      } else if (prodiSelect.value === 'Desain Produk' || prodiSelect.value === 'Desain Komunikasi Visual') {
        document.getElementById('jenis_kolokium').checked = true;
      }
    });

    // ─── Signature Pad ───
    const canvas = document.getElementById('signatureCanvas');
    const ctx = canvas.getContext('2d');
    const clearSignatureBtn = document.getElementById('clearSignatureBtn');
    const signatureError = document.getElementById('signatureError');
    const ttdInput = document.getElementById('ttd_pemohon');
    let drawing = false;
    let hasSignature = false;

    function resizeCanvas() {
      const rect = canvas.getBoundingClientRect();
      if (rect.width === 0 || rect.height === 0) return; // Prevent clearing when hidden

      const ratio = window.devicePixelRatio || 1;
      const prevData = hasSignature ? canvas.toDataURL() : null;

      canvas.width = rect.width * ratio;
      canvas.height = rect.height * ratio;
      ctx.scale(ratio, ratio);
      ctx.lineWidth = 2;
      ctx.lineCap = 'round';
      ctx.lineJoin = 'round';
      ctx.strokeStyle = '#1e3a6e';

      if (prevData) {
        const img = new Image();
        img.onload = () => ctx.drawImage(img, 0, 0, rect.width, rect.height);
        img.src = prevData;
      }
    }
    window.addEventListener('resize', resizeCanvas);
    resizeCanvas();

    function getPos(e) {
      const rect = canvas.getBoundingClientRect();
      const point = e.touches ? e.touches[0] : e;
      return { x: point.clientX - rect.left, y: point.clientY - rect.top };
    }

    function startDraw(e) {
      e.preventDefault();
      drawing = true;
      hasSignature = true;
      signatureError.classList.add('hidden');
      const pos = getPos(e);
      ctx.beginPath();
      ctx.moveTo(pos.x, pos.y);
    }

    function draw(e) {
      if (!drawing) return;
      e.preventDefault();
      const pos = getPos(e);
      ctx.lineTo(pos.x, pos.y);
      ctx.stroke();
    }

    function endDraw() {
      if (!drawing) return;
      drawing = false;
      ttdInput.value = canvas.toDataURL('image/png');
    }

    canvas.addEventListener('mousedown', startDraw);
    canvas.addEventListener('mousemove', draw);
    window.addEventListener('mouseup', endDraw);

    canvas.addEventListener('touchstart', startDraw, { passive: false });
    canvas.addEventListener('touchmove', draw, { passive: false });
    canvas.addEventListener('touchend', endDraw);

    clearSignatureBtn.addEventListener('click', () => {
      const rect = canvas.getBoundingClientRect();
      ctx.clearRect(0, 0, rect.width, rect.height);
      hasSignature = false;
      ttdInput.value = '';
    });

    // ─── Multi-step Logic ───
    function updateIndicators(step) {
      for (let i = 1; i <= 3; i++) {
        const circle = document.getElementById('ind' + i + '-circle');
        const text = document.getElementById('ind' + i + '-text');
        const line = document.getElementById('ind' + i + '-line');
        if (i < step) {
          circle.className = 'w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold shrink-0 bg-green-500 text-white';
          circle.innerHTML = '&#10003;';
          text.className = 'text-xs font-medium text-gray-500';
          if (line) line.className = 'w-8 h-px bg-blue-300';
        } else if (i === step) {
          circle.className = 'w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold shrink-0 bg-blue-600 text-white';
          circle.innerHTML = i;
          text.className = 'text-xs font-medium text-blue-600';
          if (line) line.className = 'w-8 h-px bg-gray-200';
        } else {
          circle.className = 'w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold shrink-0 bg-gray-100 text-gray-400';
          circle.innerHTML = i;
          text.className = 'text-xs font-medium text-gray-400';
          if (line) line.className = 'w-8 h-px bg-gray-200';
        }
      }
    }

    function goToStep(step, isPopState = false) {
      if (step === 2 || step === 3) {
        if (!form.checkValidity()) {
          form.reportValidity();
          return;
        }
        if (!hasSignature) {
          signatureError.classList.remove('hidden');
          canvas.scrollIntoView({ behavior: 'smooth', block: 'center' });
          return;
        }
      }

      // Save signature before leaving step 1
      if (document.getElementById('step1').classList.contains('active') && hasSignature) {
        ttdInput.value = canvas.toDataURL('image/png');
      }

      if (step === 3) populateSummary();

      document.querySelectorAll('.step-content').forEach(el => el.classList.remove('active'));
      document.getElementById('step' + step).classList.add('active');
      updateIndicators(step);
      window.scrollTo({ top: 0, behavior: 'smooth' });

      // Restore signature if returning to step 1
      if (step === 1 && hasSignature && ttdInput.value) {
        setTimeout(() => {
          const img = new Image();
          img.onload = () => {
             const rect = canvas.getBoundingClientRect();
             ctx.clearRect(0, 0, rect.width, rect.height);
             ctx.drawImage(img, 0, 0, rect.width, rect.height);
          };
          img.src = ttdInput.value;
        }, 50);
      }

      if (!isPopState) {
        history.pushState({ step: step }, '', '#step' + step);
      }
    }

    // Handle browser back/forward buttons
    window.addEventListener('popstate', (e) => {
      const step = e.state ? e.state.step : 1;
      goToStep(step, true);
    });

    // Set initial state
    history.replaceState({ step: 1 }, '', '#step1');

    function populateSummary() {
      const box = document.getElementById('ringkasanBox');
      const formData = new FormData(form);
      
      const labelMap = {
        jenis_sidang: 'Jenis Sidang',
        nama: 'Nama',
        nim: 'NIM',
        program_studi: 'Program Studi',
        alamat: 'Alamat',
        no_hp: 'No. HP',
        email: 'Email',
        judul_karya_akhir: 'Judul Karya Akhir',
        file_draft_karya_akhir: 'Draft Softfile Karya Akhir'
      };
      
      let html = '';
      for (const [key, label] of Object.entries(labelMap)) {
        let val = formData.get(key);
        if (val instanceof File) {
          val = val.name || 'Belum ada file dipilih';
        } else {
          val = val || '-';
          if (key === 'jenis_sidang') val = val === 'seminar_proposal' ? 'Sidang Seminar Proposal' : 'Sidang Kolokium';
        }
        
        html += `<div class="px-4 py-3 border-b" style="border-color: #e6ecf5;">
          <p class="text-[11px] font-semibold uppercase tracking-wide" style="color: #7c8aa5;">${label}</p>
          <p class="mt-0.5">${val}</p>
        </div>`;
      }
      box.innerHTML = html;
      document.getElementById('ttdPreviewImg').src = canvas.toDataURL('image/png');
    }

    // Submit handler
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const submitBtn = document.getElementById('submitBtn');
      const submitBtnText = document.getElementById('submitBtnText');
      
      submitBtn.disabled = true;
      submitBtnText.textContent = 'Mengirim...';
      sessionStorage.removeItem('pengajuan_sidang_step1'); // clear legacy state
      
      const formData = new FormData(form);
      const backendCookie = "<%= user.backendCookie || '' %>";
      const backendUrl = "<%= locals.backendBaseUrl ? backendBaseUrl : 'http://localhost:5000' %>/api/proposal";
      
      try {
        const response = await fetch(backendUrl, {
          method: 'POST',
          headers: {
            'x-backend-cookie': backendCookie
          },
          body: formData
        });

        const result = await response.json();

        if (response.ok && result.success) {
          window.location.href = '/dashboard/pemohon/data-management?success=1';
        } else {
          throw new Error(result.error || 'Terjadi kesalahan saat mengirim pengajuan.');
        }
      } catch (err) {
        alert('Gagal mengirim pengajuan: ' + err.message);
        submitBtn.disabled = false;
        submitBtnText.textContent = 'Kirim Pengajuan';
      }
    });

    document.getElementById('saveCloseBtn').addEventListener('click', () => {
      window.location.href = '/dashboard/pemohon';
    });
  </script>

</body>
</html>